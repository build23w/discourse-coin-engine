  $$('[data-wr-filter]').forEach(function(b){
    b.addEventListener('click', function(){ loadWithdrawRequests(b.getAttribute('data-wr-filter')); });
  });
  loadWithdrawRequestStats();

  // ---------- Custodial wallet backfill banner (v0.11.0) ----------
  function loadWalletStatus(){
    get('/admin/coin-engine/wallets/status.json').then(function(d){
      var banner = $('#ce-wallet-banner');
      var title  = $('#ce-wallet-banner-title');
      var detail = $('#ce-wallet-banner-detail');
      var btn    = $('#ce-wallet-backfill');
      if (!banner || !d) return;
      var users = (d.users_missing == null) ? '?' : d.users_missing;
      var custodial = (d.custodial_count == null) ? '?' : d.custodial_count;
      if (d.passphrase_set && d.users_missing === 0){ banner.hidden = true; return; }
      banner.hidden = false;
      if (!d.passphrase_set){
        banner.classList.add('ce-wallet-banner--warn');
        banner.classList.remove('ce-wallet-banner--info');
        title.textContent = '\u26A0\uFE0F Set the wallet encryption passphrase';
        detail.innerHTML = 'Auto-gen and Export are disabled until <code>coin_engine_wallet_encryption_passphrase</code> is set. ' +
          '<a href="/admin/site_settings/category/plugins?filter=coin_engine_wallet" target="_blank">Open settings &rarr;</a>';
        btn.hidden = true;
        return;
      }
      banner.classList.add('ce-wallet-banner--info');
      banner.classList.remove('ce-wallet-banner--warn');
      title.textContent = users + ' user' + (users === 1 ? '' : 's') + ' need a custodial wallet';
      detail.innerHTML = fmtN(custodial) + ' custodial wallet' + (custodial === 1 ? '' : 's') + ' on file. ' +
        'Backfill enqueues a Sidekiq job per user (50/sec). ' +
        (d.last_backfill_at ? 'Last run: ' + fmtRel(d.last_backfill_at) + '.' : '');
      if (users > 0){
        btn.hidden = false; btn.disabled = false;
        btn.textContent = users <= d.hard_cap ? ('Generate ' + fmtN(users) + ' wallets') : ('Generate ' + fmtN(d.hard_cap) + ' (cap)');
      } else {
        btn.hidden = true;
      }
    }).catch(function(){
      var banner = $('#ce-wallet-banner'); if (banner) banner.hidden = true;
    });
  }
  if ($('#ce-wallet-backfill')){
    $('#ce-wallet-backfill').addEventListener('click', function(){
      var btn = $('#ce-wallet-backfill');
      if (!confirm('Enqueue wallet generation jobs now? Sidekiq will process ~50/second.')) return;
      btn.disabled = true; var orig = btn.textContent; btn.textContent = 'Enqueuing...';
      post('/admin/coin-engine/wallets/backfill.json', {}).then(function(d){
        toast('Enqueued ' + fmtN(d.enqueued || 0) + ' wallet generation jobs.', 'win');
        btn.textContent = '\u2713 ' + fmtN(d.enqueued || 0) + ' enqueued';
        setTimeout(loadWalletStatus, 8000);
      }).catch(function(e){
        toast((e && e.errors && e.errors[0]) || 'Backfill failed.', 'err');
        btn.disabled = false; btn.textContent = orig;
      });
    });
  }
  loadWalletStatus();

  var state = { selectedUser: null, recentPage: 1, usersPage: 1, recentLoaded: false, usersLoaded: false, mintsLoaded: false };

  // ---------- Pay tab: typeahead ----------
  var payQ = $('#ce-pay-q'), payTA = $('#ce-pay-ta'), payTimer = null;
  payQ.addEventListener('input', function(){
    clearTimeout(payTimer);
    var q = payQ.value.trim();
    if (q.length < 2){ payTA.classList.remove('is-open'); payTA.innerHTML = ''; return; }
    payTimer = setTimeout(function(){
      get('/admin/coin-engine/users/search.json?q=' + encodeURIComponent(q)).then(function(d){
        var rows = (d.users || []).map(function(u){
          return '<div class="ce-ta-row" data-uid="' + u.id + '" data-uname="' + esc(u.username) + '" data-wallet="' + esc(u.wallet || '') + '" data-avail="' + (u.available_to_send || 0) + '"><strong>' + esc(u.username) + '</strong>' + (u.name ? ' <span style="color:#5a6573">— ' + esc(u.name) + '</span>' : '') + '<div class="ce-ta-meta">' + (u.email ? esc(u.email) + ' · ' : '') + 'TL' + (u.trust_level || 0) + ' · ' + fmtN(u.score || 0) + ' $RENO' + (u.wallet ? ' · 🔗 wallet linked' : '') + '</div></div>';
        }).join('');
        payTA.innerHTML = rows || '<div class="ce-ta-row" style="cursor:default;color:#8b95a3">No matches</div>';
        payTA.classList.add('is-open');
        $$('.ce-ta-row[data-uid]', payTA).forEach(function(r){
          r.addEventListener('click', function(){
            state.selectedUser = { id: r.getAttribute('data-uid'), username: r.getAttribute('data-uname'), wallet: r.getAttribute('data-wallet'), available: parseInt(r.getAttribute('data-avail') || '0', 10) };
            payQ.value = state.selectedUser.username;
            payTA.classList.remove('is-open');
            var sel = $('#ce-pay-selected'); sel.hidden = false; sel.innerHTML = '✓ Selected: <strong>@' + esc(state.selectedUser.username) + '</strong>' + (state.selectedUser.available != null ? ' · max payable: <strong>' + fmtN(state.selectedUser.available) + '</strong>' : '') + (state.selectedUser.wallet ? ' · 🔗 wallet linked' : ' · ⚠️ no wallet linked (on-chain disabled)');
          });
        });
      });
    }, 220);
  });
  document.addEventListener('click', function(e){ if (!payQ.contains(e.target) && !payTA.contains(e.target)) payTA.classList.remove('is-open'); });

  $('#ce-pay-submit').addEventListener('click', function(){
    if (!state.selectedUser){ toast('Select a recipient first', 'err'); return; }
    var amt = parseInt($('#ce-pay-amt').value, 10) || 0;
    if (amt <= 0){ toast('Amount must be positive', 'err'); return; }
    var btn = $('#ce-pay-submit'); btn.disabled = true; btn.textContent = 'Sending...';
    post('/admin/coin-engine/payments.json', {
      user_id: state.selectedUser.id,
      amount: amt,
      reason: $('#ce-pay-reason').value,
      note: $('#ce-pay-note').value,
      wallet_address: $('#ce-pay-wallet').value.trim() || null,
    }).then(function(d){
      toast('Payment sent: +' + amt + ' $RENO to @' + state.selectedUser.username, 'win');
      $('#ce-pay-amt').value = ''; $('#ce-pay-note').value = ''; $('#ce-pay-wallet').value = '';
      $('#ce-pay-q').value = ''; $('#ce-pay-selected').hidden = true; state.selectedUser = null;
      state.recentLoaded = false; state.mintsLoaded = false;  // force-refresh
      loadStats();
    }).catch(function(err){
      toast((err && err.errors && err.errors[0]) || 'Payment failed', 'err');
    }).finally(function(){
      btn.disabled = false; btn.textContent = 'Send payment';
    });
  });

  // ---------- Recent tab ----------
  function loadRecent(){
    state.recentLoaded = true;
    var page = state.recentPage;
    get('/admin/coin-engine/payments.json?page=' + (page - 1) + '&limit=25').then(function(d){
      var rows = (d.payments || []);
      var body = $('#ce-recent-body');
      if (!rows.length){ body.innerHTML = '<tr><td colspan="6" class="ce-empty">No payments yet on this page.</td></tr>'; }
      else {
        body.innerHTML = rows.map(function(p){
          var status = p.tx_signature ? '<span class="ce-pill ce-pill-mint">Minted</span>' : '<span class="ce-pill ce-pill-sent">Sent</span>';
          var tx = p.tx_signature ? '<span class="ce-pill ce-pill-tx" title="' + esc(p.tx_signature) + '">' + esc(p.tx_signature.slice(0,8)) + '…' + esc(p.tx_signature.slice(-4)) + '</span>' : '<em style="color:#8b95a3">—</em>';
          return '<tr><td>' + fmtRel(p.sent_at || p.created_at) + '<div style="font-size:11px;color:#8b95a3">' + fmtFull(p.sent_at || p.created_at) + '</div></td>'
            + '<td><a href="/u/' + esc(p.username || '') + '" target="_blank">@' + esc(p.username || '?') + '</a></td>'
            + '<td class="ce-num"><strong>' + fmtN(p.amount) + '</strong></td>'
            + '<td>' + esc(p.reason || '—') + (p.note ? '<div style="font-size:11px;color:#8b95a3;margin-top:2px">' + esc(p.note) + '</div>' : '') + '</td>'
            + '<td>' + status + '</td>'
            + '<td>' + tx + '</td></tr>';
        }).join('');
      }
      $('#ce-recent-info').textContent = 'Page ' + page + (d.total ? ' · ' + d.total + ' total' : '');
      $('#ce-recent-prev').disabled = page <= 1;
      $('#ce-recent-next').disabled = rows.length < 25;
    }).catch(function(){
      $('#ce-recent-body').innerHTML = '<tr><td colspan="6" class="ce-empty">Failed to load. Retry.</td></tr>';
    });
  }
  $('#ce-recent-prev').addEventListener('click', function(){ if (state.recentPage > 1){ state.recentPage--; loadRecent(); }});
  $('#ce-recent-next').addEventListener('click', function(){ state.recentPage++; loadRecent(); });

  // ---------- Users tab ----------
  function loadUsers(){
    state.usersLoaded = true;
    var page = state.usersPage;
    var q = $('#ce-users-q').value.trim();
    var sort = $('#ce-users-sort').value;
    get('/admin/coin-engine/users.json?page=' + page + '&per_page=25&q=' + encodeURIComponent(q) + '&sort=' + encodeURIComponent(sort)).then(function(d){
      var rows = (d.users || []);
      var body = $('#ce-users-body');
      if (!rows.length){ body.innerHTML = '<tr><td colspan="6" class="ce-empty">No users match.</td></tr>'; }
      else {
        body.innerHTML = rows.map(function(u){
          var wallet = u.wallet ? '<span class="ce-pill ce-pill-tx" title="' + esc(u.wallet) + '">' + esc(u.wallet.slice(0,6) + '…' + u.wallet.slice(-4)) + '</span>' : '<em style="color:#8b95a3">none</em>';
          return '<tr><td><a href="/u/' + esc(u.username) + '" target="_blank">@' + esc(u.username) + '</a>' + (u.name ? '<div style="font-size:11px;color:#8b95a3">' + esc(u.name) + '</div>' : '') + '</td>'
            + '<td class="ce-num"><strong>' + fmtN(u.score) + '</strong></td>'
            + '<td class="ce-num">' + fmtN(u.lifetime_received) + '</td>'
            + '<td>' + (u.last_paid_at ? fmtRel(u.last_paid_at) : '<em style="color:#8b95a3">never</em>') + '</td>'
            + '<td>' + wallet + '</td>'
            + '<td><button class="ce-btn" data-payu="' + u.id + '" data-payname="' + esc(u.username) + '">Pay →</button></td></tr>';
        }).join('');
        $$('button[data-payu]', body).forEach(function(b){
          b.addEventListener('click', function(){
            state.selectedUser = { id: b.getAttribute('data-payu'), username: b.getAttribute('data-payname'), wallet: '' };
            $('#ce-pay-q').value = state.selectedUser.username;
            $('#ce-pay-selected').hidden = false; $('#ce-pay-selected').innerHTML = '✓ Selected: <strong>@' + esc(state.selectedUser.username) + '</strong>';
            $$('.ce-tab[data-tab="pay"]')[0].click();
            $('#ce-pay-amt').focus();
          });
        });
      }
      $('#ce-users-info').textContent = 'Page ' + page + (d.total ? ' · ' + d.total + ' users' : '');
      $('#ce-users-prev').disabled = page <= 1;
      $('#ce-users-next').disabled = rows.length < 25;
    }).catch(function(){
      $('#ce-users-body').innerHTML = '<tr><td colspan="6" class="ce-empty">Failed to load. Retry.</td></tr>';
    });
  }
  var usersTimer = null;
  $('#ce-users-q').addEventListener('input', function(){ clearTimeout(usersTimer); usersTimer = setTimeout(function(){ state.usersPage = 1; loadUsers(); }, 250); });
  $('#ce-users-sort').addEventListener('change', function(){ state.usersPage = 1; loadUsers(); });
  $('#ce-users-prev').addEventListener('click', function(){ if (state.usersPage > 1){ state.usersPage--; loadUsers(); }});
  $('#ce-users-next').addEventListener('click', function(){ state.usersPage++; loadUsers(); });

  // ---------- Mints tab ----------
  function loadMints(){
    state.mintsLoaded = true;
    get('/admin/coin-engine/payments.json?per_page=100&pending_mint=1').then(function(d){
      var rows = (d.payments || []).filter(function(p){ return !p.tx_signature; });
      var body = $('#ce-mints-body');
      if (!rows.length){ body.innerHTML = '<div class="ce-empty">All payments are minted. Nothing pending.</div>'; return; }
      body.innerHTML = rows.map(function(p){
        return '<div class="ce-mint-row" data-pid="' + p.id + '">'
          + '<div class="ce-mint-meta"><strong>+' + fmtN(p.amount) + ' $RENO</strong> to <a href="/u/' + esc(p.username || '') + '" target="_blank">@' + esc(p.username || '?') + '</a> · ' + fmtRel(p.sent_at || p.created_at) + ' · reason: ' + esc(p.reason || '—') + '</div>'
          + '<div class="ce-mint-input"><input type="text" class="ce-input" placeholder="Paste Solana transaction signature (base58)" data-pid="' + p.id + '"><button class="ce-btn ce-btn-primary" data-mintp="' + p.id + '">Mark minted</button></div>'
          + '</div>';
      }).join('');
      $$('button[data-mintp]', body).forEach(function(btn){
        btn.addEventListener('click', function(){
          var pid = btn.getAttribute('data-mintp');
          var input = body.querySelector('input[data-pid="' + pid + '"]');
          var sig = (input && input.value || '').trim();
          if (!sig){ toast('Paste the Solana tx signature first', 'err'); return; }
          btn.disabled = true; btn.textContent = 'Saving...';
          put('/admin/coin-engine/payments/' + pid + '/tx.json', { tx_signature: sig }).then(function(){
            toast('Marked as minted', 'win');
            var row = body.querySelector('.ce-mint-row[data-pid="' + pid + '"]');
            if (row){ row.classList.add('ce-mint-done'); btn.textContent = '✓ Done'; input.disabled = true; }
            loadStats();
            state.recentLoaded = false;
          }).catch(function(err){
            toast((err && err.errors && err.errors[0]) || 'Failed to save tx', 'err');
            btn.disabled = false; btn.textContent = 'Mark minted';
          });
        });
      });
    }).catch(function(){
      $('#ce-mints-body').innerHTML = '<div class="ce-empty">Failed to load pending mints.</div>';
    });
  }

  // Boot
  loadStats();
  setInterval(loadStats, 60000); // refresh stats every minute
})();
</script>

<%# v0.8.0 — Solana on-chain payment integration. Browser-side only:
    admin connects Phantom wallet, signs each transfer manually. We never
    store private keys. SPL token transfer = create-ATA-if-missing + transfer.
%>
<script nonce="<%= csp_nonce_placeholder %>" src="https://unpkg.com/@solana/web3.js@1.95.5/lib/index.iife.min.js"></script>
<script nonce="<%= csp_nonce_placeholder %>">
(function(){
  if (window.__lfCESolanaLoaded) return; window.__lfCESolanaLoaded = true;

  // ---------- Config from server ----------
  var SOL_MINT     = "<%= j SiteSetting.coin_engine_solana_mint_address.to_s %>";
  var SOL_RPC_DEFAULT = "<%= j SiteSetting.coin_engine_solana_rpc_url.to_s %>";
  var SOL_DECIMALS = parseInt("<%= SiteSetting.coin_engine_solana_decimals.to_i %>", 10) || 9;
  var SOL_MIN      = parseInt("<%= SiteSetting.coin_engine_solana_min_send_threshold.to_i %>", 10) || 20000;
  var COIN_NAME    = "<%= j SiteSetting.coin_engine_coin_name.to_s %>";

  // v0.8.4 — RPC selection. The public mainnet-beta RPC frequently 403s browser
  // requests. Admin can paste a private RPC override (Helius/QuickNode/Triton)
  // which we cache in localStorage so it persists across sessions. We also keep
  // a small CORS-friendly fallback list to try automatically when the chosen
  // RPC returns 403/429.
  function getRpcOverride(){
    try { return localStorage.getItem('lf_ce_admin_rpc') || ''; } catch(_){ return ''; }
  }
  function setRpcOverride(url){
    try { if (url) localStorage.setItem('lf_ce_admin_rpc', url); else localStorage.removeItem('lf_ce_admin_rpc'); } catch(_){}
  }
  function activeRpc(){ return getRpcOverride() || SOL_RPC_DEFAULT || 'https://api.mainnet-beta.solana.com'; }
  // Public RPCs that historically respond to browser fetches (CORS-friendly).
  // Private/paid RPCs (Helius/QuickNode) should be set as the override above.
  var PUBLIC_RPC_FALLBACKS = [
    'https://solana-rpc.publicnode.com',
    'https://rpc.ankr.com/solana',
    'https://api.mainnet-beta.solana.com',
  ];
  function rpcCandidates(){
    var seen = {}, out = [];
    [activeRpc()].concat(PUBLIC_RPC_FALLBACKS).forEach(function(u){
      if (u && !seen[u]){ seen[u] = 1; out.push(u); }
    });
    return out;
  }

  function $(s, r){ return (r||document).querySelector(s); }
  function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, function(c){ return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]; }); }
  function toast(m, k){ var t=document.createElement('div'); t.className='ce-toast'+(k?' ce-toast-'+k:''); t.textContent=m; document.body.appendChild(t); setTimeout(function(){t.classList.add('ce-toast-out');},2400); setTimeout(function(){if(t.parentNode)t.parentNode.removeChild(t);},3000); }

  // ---------- Wallet state ----------
  var wallet = { connected: false, pubkey: null };
  function loadStoredConnection(){
    try {
      var saved = localStorage.getItem('lf_ce_admin_wallet');
      if (saved){ wallet.pubkey = saved; wallet.connected = true; }
    } catch(_){}
  }
  function saveConnection(pk){
    try { localStorage.setItem('lf_ce_admin_wallet', pk); } catch(_){}
  }
  function clearConnection(){
    try { localStorage.removeItem('lf_ce_admin_wallet'); } catch(_){}
    wallet.connected = false; wallet.pubkey = null;
  }

  // ---------- Inject UI ----------
  function injectChainPanel(){
    if (document.getElementById('ce-chain-panel')) return;
    var payPanel = document.getElementById('ce-pane-pay');
    if (!payPanel) return;
    var configured = !!SOL_MINT;
    var html =
      '<div id="ce-chain-panel" style="margin-bottom:18px;padding:14px;border-radius:12px;background:linear-gradient(135deg,#0f1624,#1d2a44);color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">'+
        '<div style="flex:1;min-width:240px">'+
          '<div style="font-size:11.5px;text-transform:uppercase;letter-spacing:.6px;opacity:.65;font-weight:700">⛓️ On-chain payments</div>'+
          '<div id="ce-chain-status" style="font-size:14px;font-weight:700;margin-top:4px"></div>'+
          '<div id="ce-chain-detail" style="font-size:11.5px;opacity:.7;margin-top:3px"></div>'+
        '</div>'+
        '<div id="ce-chain-actions" style="display:flex;gap:8px;flex-wrap:wrap"></div>'+
      '</div>';
    payPanel.insertAdjacentHTML('afterbegin', html);
    renderChainStatus();
  }
  function renderChainStatus(){
    var statusEl = $('#ce-chain-status'); var detailEl = $('#ce-chain-detail'); var actionsEl = $('#ce-chain-actions');
    if (!statusEl) return;
    if (!SOL_MINT){
      statusEl.innerHTML = '⚠️ Mint address not configured';
      detailEl.textContent = 'Set coin_engine_solana_mint_address in Site Settings to enable on-chain transfers.';
      actionsEl.innerHTML = '<a href="/admin/site_settings/category/plugins?filter=coin_engine_solana" target="_blank" style="color:#fff;text-decoration:underline;font-size:12.5px">Configure →</a>';
      return;
    }
    if (!window.solana){
      statusEl.innerHTML = '🦊 Phantom wallet not detected';
      detailEl.textContent = 'Install Phantom (phantom.app) to enable on-chain payments. Manual recording still works without it.';
      actionsEl.innerHTML = '<a href="https://phantom.app" target="_blank" style="color:#fff;text-decoration:underline;font-size:12.5px">Install Phantom →</a>';
      return;
    }
    if (wallet.connected && wallet.pubkey){
      var short = wallet.pubkey.slice(0,6)+'…'+wallet.pubkey.slice(-4);
      var rpcHost = activeRpc().replace(/^https?:\/\//,'').split('/')[0];
      var rpcOverridden = !!getRpcOverride();
      statusEl.innerHTML = '✅ Connected · <code style="background:rgba(255,255,255,.12);padding:1px 6px;border-radius:4px;font-size:12px;font-family:ui-monospace,Menlo,monospace">'+esc(short)+'</code>';
      detailEl.innerHTML = 'Mint: '+SOL_MINT.slice(0,6)+'…'+SOL_MINT.slice(-4)+' · Min on-chain send: '+SOL_MIN.toLocaleString()+' '+esc(COIN_NAME)+
        ' · RPC: <span style="color:'+(rpcOverridden?'#ffd166':'#fff')+'">'+esc(rpcHost)+'</span>'+
        (rpcOverridden? ' <em style="font-size:10px;opacity:.7">(custom)</em>' : '');
      actionsEl.innerHTML =
        '<button class="ce-btn" id="ce-chain-rpc" style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2)">RPC URL</button>'+
        '<button class="ce-btn" id="ce-chain-disconnect" style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2)">Disconnect</button>';
      $('#ce-chain-rpc').addEventListener('click', editRpcOverride);
      $('#ce-chain-disconnect').addEventListener('click', function(){ clearConnection(); renderChainStatus(); injectOnChainToggle(); });
    } else {
      statusEl.textContent = 'Wallet not connected';
      detailEl.textContent = 'Connect to enable on-chain auto-mint when issuing payments. Without connection, payments still record (admins can mint manually later).';
      actionsEl.innerHTML = '<button class="ce-btn ce-btn-primary" id="ce-chain-connect">Connect Phantom Wallet</button>';
      $('#ce-chain-connect').addEventListener('click', connectWallet);
    }
    injectOnChainToggle();
  }

  function editRpcOverride(){
    var current = getRpcOverride();
    var msg = 'Enter your private Solana RPC URL.\n\n' +
              'The public mainnet-beta RPC frequently 403s browser requests.\n' +
              'Recommended providers (free tiers available):\n' +
              '  • Helius — https://mainnet.helius-rpc.com/?api-key=YOUR_KEY\n' +
              '  • QuickNode — https://YOUR-NAME.solana-mainnet.quiknode.pro/YOUR_KEY/\n' +
              '  • Triton — https://api.rpcpool.com/YOUR_KEY/\n\n' +
              'Leave blank to use the site setting + public fallbacks.';
    var v = prompt(msg, current || '');
    if (v === null) return; // cancelled
    v = (v || '').trim();
    if (v && !/^https?:\/\//i.test(v)){ alert('RPC URL must start with http:// or https://'); return; }
    setRpcOverride(v);
    toast(v ? 'Custom RPC saved' : 'Reverted to default RPC', 'win');
    renderChainStatus();
  }

  async function connectWallet(){
    if (!window.solana){ toast('Phantom not detected', 'err'); return; }
    try {
      var resp = await window.solana.connect();
      var pk = resp.publicKey ? resp.publicKey.toString() : (window.solana.publicKey && window.solana.publicKey.toString());
      if (!pk) throw new Error('No public key returned');
      wallet.connected = true; wallet.pubkey = pk; saveConnection(pk);
      toast('Wallet connected: '+pk.slice(0,6)+'…'+pk.slice(-4), 'win');
      renderChainStatus();
    } catch(e){ toast('Wallet connection rejected', 'err'); }
  }

  // ---------- "Send on-chain" toggle in Pay form ----------
  function injectOnChainToggle(){
    var actionsRow = document.querySelector('#ce-pane-pay .ce-toolbar:last-of-type');
    if (!actionsRow) return;
    var existing = document.getElementById('ce-pay-onchain-wrap');
    if (existing) existing.remove();
    var wrap = document.createElement('div');
    wrap.id = 'ce-pay-onchain-wrap';
    wrap.style.cssText = 'flex:1;display:flex;align-items:center;gap:8px;font-size:13px;color:#5a6573';
    var disabled = !(SOL_MINT && wallet.connected && window.solana);
    wrap.innerHTML =
      '<label style="display:inline-flex;align-items:center;gap:8px;cursor:'+(disabled?'not-allowed':'pointer')+';opacity:'+(disabled?'.5':'1')+'">'+
        '<input type="checkbox" id="ce-pay-onchain" '+(disabled?'disabled':'')+' style="width:16px;height:16px;cursor:'+(disabled?'not-allowed':'pointer')+'">'+
        '<span><strong>Auto-mint on Solana</strong>'+(disabled? ' (connect wallet first)' : ' (admin signs in Phantom)')+'</span>'+
      '</label>';
    actionsRow.insertBefore(wrap, actionsRow.firstChild);
  }

  // ---------- SPL token transfer ----------
  async function getRecipientWallet(username){
    // Backend already returns wallet on the user search response. Re-fetch to be safe.
    var r = await fetch('/admin/coin-engine/users.json?per_page=1&q='+encodeURIComponent(username), { credentials:'same-origin', headers: { 'Accept':'application/json' } });
    var d = await r.json();
    var u = (d.users || []).find(function(x){ return (x.username||'').toLowerCase() === username.toLowerCase(); });
    return u && u.wallet;
  }

  // SPL Token + Associated Token Account program IDs (constants on every cluster)
  var SPL_TOKEN_PROGRAM_ID         = "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA";
  var ASSOCIATED_TOKEN_PROGRAM_ID  = "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL";
  var SYSTEM_PROGRAM_ID            = "11111111111111111111111111111111";

  // Derive an Associated Token Account (ATA) address: PDA of [owner, TOKEN_PROGRAM, mint] under ATA_PROGRAM.
  function deriveAta(web3, ownerPk, mintPk){
    return web3.PublicKey.findProgramAddressSync(
      [ownerPk.toBuffer(), new web3.PublicKey(SPL_TOKEN_PROGRAM_ID).toBuffer(), mintPk.toBuffer()],
      new web3.PublicKey(ASSOCIATED_TOKEN_PROGRAM_ID)
    )[0];
  }

  // Build a "create ATA" instruction (no instruction data, accounts in fixed order).
  function buildCreateAtaIx(web3, payer, ata, owner, mint){
    return new web3.TransactionInstruction({
      keys: [
        { pubkey: payer,                                         isSigner: true,  isWritable: true  },
        { pubkey: ata,                                           isSigner: false, isWritable: true  },
        { pubkey: owner,                                         isSigner: false, isWritable: false },
        { pubkey: mint,                                          isSigner: false, isWritable: false },
        { pubkey: new web3.PublicKey(SYSTEM_PROGRAM_ID),         isSigner: false, isWritable: false },
        { pubkey: new web3.PublicKey(SPL_TOKEN_PROGRAM_ID),      isSigner: false, isWritable: false },
      ],
      programId: new web3.PublicKey(ASSOCIATED_TOKEN_PROGRAM_ID),
      data: new Uint8Array(0),
    });
  }

  // Build SPL Transfer instruction. Layout: [3 (Transfer opcode), amount as u64 little-endian].
  function buildSplTransferIx(web3, sourceAta, destAta, ownerPk, rawAmount){
    var data = new Uint8Array(9);
    data[0] = 3; // Transfer instruction discriminator
    var view = new DataView(data.buffer);
    view.setBigUint64(1, BigInt(rawAmount), true);
    return new web3.TransactionInstruction({
      keys: [
        { pubkey: sourceAta, isSigner: false, isWritable: true  },
        { pubkey: destAta,   isSigner: false, isWritable: true  },
        { pubkey: ownerPk,   isSigner: true,  isWritable: false },
      ],
      programId: new web3.PublicKey(SPL_TOKEN_PROGRAM_ID),
      data: data,
    });
  }

  // v0.8.4 — try a list of RPC URLs in sequence; the first one that successfully
  // serves a getAccountInfo + getLatestBlockhash wins. This sidesteps the public
  // mainnet-beta RPC's frequent 403/429 by falling through to publicnode/Ankr.
  async function tryRpcChain(web3, fn){
    var candidates = rpcCandidates();
    var lastErr = null;
    for (var i = 0; i < candidates.length; i++){
      var url = candidates[i];
      try {
        var conn = new web3.Connection(url, 'confirmed');
        var result = await fn(conn);
        if (i > 0){ toast('RPC fallback used: '+url.replace(/^https?:\/\//,'').split('/')[0], 'info'); }
        return { conn: conn, url: url, result: result };
      } catch (e){
        lastErr = e;
        var msg = (e && e.message) || String(e);
        console.warn('[ce-solana] RPC '+url+' failed: '+msg);
        // Keep trying on 403/429/network failures; bail on programming errors.
        if (!/403|429|forbidden|rate|fetch|cors|network|timeout/i.test(msg)){
          throw e;
        }
      }
    }
    var pretty = lastErr && lastErr.message ? lastErr.message : 'unknown';
    var err = new Error('All Solana RPCs returned errors. Last: '+pretty+'\n\nClick "RPC URL" in the on-chain banner to set a private RPC (Helius, QuickNode, Triton).');
    err.cause = lastErr;
    throw err;
  }

  async function sendSplTransfer(recipientPubkeyStr, amount){
    var web3 = window.solanaWeb3;
    if (!web3) throw new Error('Solana web3.js not loaded -- check console for CDN load errors');

    var sender    = window.solana.publicKey;
    var recipient = new web3.PublicKey(recipientPubkeyStr);
    var mint      = new web3.PublicKey(SOL_MINT);

    var senderAta    = deriveAta(web3, sender, mint);
    var recipientAta = deriveAta(web3, recipient, mint);

    // Step 1: figure out if recipient ATA exists, using fallback chain.
    var rcptResult = await tryRpcChain(web3, async function(conn){
      return await conn.getAccountInfo(recipientAta);
    });
    var workingConn = rcptResult.conn;
    var rcptInfo = rcptResult.result;

    var instructions = [];
    if (!rcptInfo){
      instructions.push(buildCreateAtaIx(web3, sender, recipientAta, recipient, mint));
    }
    var rawAmount = BigInt(amount) * (BigInt(10) ** BigInt(SOL_DECIMALS));
    instructions.push(buildSplTransferIx(web3, senderAta, recipientAta, sender, rawAmount));

    // Step 2: get blockhash on the same RPC that worked above.
    var blockhash;
    try {
      blockhash = await workingConn.getLatestBlockhash('confirmed');
    } catch(e){
      var bhResult = await tryRpcChain(web3, async function(conn){
        return await conn.getLatestBlockhash('confirmed');
      });
      blockhash = bhResult.result;
      workingConn = bhResult.conn;
    }

    var tx = new web3.Transaction({ recentBlockhash: blockhash.blockhash, feePayer: sender });
    instructions.forEach(function(ix){ tx.add(ix); });

    // Phantom uses its own RPC for the actual broadcast, so this works even when
    // the browser-side RPC is 403'd. Our fallback chain only covers preflight.
    var signed = await window.solana.signAndSendTransaction(tx);
    var sig = signed.signature || signed;

    // Step 3: confirm on whichever RPC is currently working.
    try {
      await workingConn.confirmTransaction({ signature: sig, blockhash: blockhash.blockhash, lastValidBlockHeight: blockhash.lastValidBlockHeight }, 'confirmed');
    } catch(e){
      console.warn('[ce-solana] confirmTransaction failed (tx may still have landed):', e && e.message);
    }
    return sig;
  }

  // ---------- Hook the existing payment submit ----------
  function hookPaymentSubmit(){
    var btn = document.getElementById('ce-pay-submit');
    if (!btn || btn.__lfWeb3Wrapped) return;
    btn.__lfWeb3Wrapped = true;

    btn.addEventListener('click', async function(e){
      var checkbox = document.getElementById('ce-pay-onchain');
      if (!checkbox || !checkbox.checked) return;
    }, true);

    // Intercept window.fetch ONLY for our specific POST so we can chain after success
    var origFetch = window.fetch;
    window.fetch = function(url, opts){
      var p = origFetch.apply(this, arguments);
      if (url === '/admin/coin-engine/payments.json' && opts && opts.method === 'POST'){
        var checkbox = document.getElementById('ce-pay-onchain');
        if (checkbox && checkbox.checked && wallet.connected){
          p = p.then(async function(resp){
            try {
              var clone = resp.clone();
              var d = await clone.json();
              if (d && d.ok && d.payment){
                var amt = d.payment.amount;
                var username = d.payment.username || (d.payment.user && d.payment.user.username);
                var recipientWallet = d.payment.wallet || (username ? await getRecipientWallet(username) : null);
                if (!recipientWallet){
                  toast('Recipient has no wallet linked. Recorded only — they can claim later.', 'info');
                  return resp;
                }
                toast('Signing transaction in Phantom...', 'info');
                var sig = await sendSplTransfer(recipientWallet, amt);
                await origFetch('/admin/coin-engine/payments/'+d.payment.id+'/tx.json', {
                  method: 'PUT', credentials: 'same-origin',
                  headers: { 'Content-Type':'application/json', 'X-CSRF-Token': (document.querySelector('meta[name=csrf-token]')||{}).getAttribute && document.querySelector('meta[name=csrf-token]').getAttribute('content') },
                  body: JSON.stringify({ tx_signature: sig })
                });
                toast('✅ Minted on-chain · '+sig.slice(0,8)+'…', 'win');
              }
            } catch(err){
              var msg = err && err.message ? err.message : String(err);
              if (/403|forbidden|All Solana RPCs/i.test(msg)){
                toast('RPC blocked. Click "RPC URL" in the on-chain banner to set a private RPC.', 'err');
              } else {
                toast('On-chain mint failed: '+msg.split('\n')[0], 'err');
              }
              console.error('[ce-solana]', err);
            }
            return resp;
          });
        }
      }
      return p;
    };
  }

  // ---------- Boot ----------
  function boot(){
    loadStoredConnection();
    injectChainPanel();
    hookPaymentSubmit();
    if (window.solana && window.solana.connect){
      window.solana.connect({ onlyIfTrusted: true }).then(function(r){
        if (r && r.publicKey){ wallet.pubkey = r.publicKey.toString(); wallet.connected = true; saveConnection(wallet.pubkey); renderChainStatus(); }
      }).catch(function(){});
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else setTimeout(boot, 50);

  // ===== v0.10.1 Verified Pro tab =====
  var vpState = { filter: 'pending', page: 1 };
  function vpEsc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, function(c){ return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]; }); }
  function vpRender(records){
    var body = document.getElementById('ce-vp-body');
    if (!body) return;
    if (!records || !records.length){ body.innerHTML = '<div class="ce-empty">No applications in this status.</div>'; return; }
    body.innerHTML = records.map(function(r){
      var u = r.user || {};
      var ageDays = u.created_at ? Math.floor((Date.now() - new Date(u.created_at).getTime()) / 86400000) : '?';
      var ageWarn = (typeof ageDays === 'number' && ageDays < 14) ? ' style="color:#c53030;font-weight:800"' : '';
      var statusPill = ({pending:'ce-pill-pending',verified:'ce-pill-sent',rejected:'ce-pill-tx',revoked:'ce-pill-tx'})[r.status] || 'ce-pill-tx';
      var actions = (r.status === 'pending')
        ? '<button class="ce-btn ce-btn-primary" data-vp-act="approve" data-vp-uid="' + u.id + '">✓ Approve</button>' +
          '<button class="ce-btn" data-vp-act="reject" data-vp-uid="' + u.id + '">Reject</button>' +
          '<button class="ce-btn" data-vp-act="info" data-vp-uid="' + u.id + '">Request more info</button>'
        : (r.status === 'verified'
          ? '<button class="ce-btn ce-btn-danger" data-vp-act="revoke" data-vp-uid="' + u.id + '">Revoke</button>'
          : '<button class="ce-btn" data-vp-act="approve" data-vp-uid="' + u.id + '">Re-approve</button>');
      return '<div class="ce-mint-row" style="margin-bottom:10px">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:8px">' +
          '<div>' +
            '<strong style="font-size:14.5px">@' + vpEsc(u.username || '?') + '</strong>' +
            '<span class="ce-pill ' + statusPill + '" style="margin-left:8px">' + r.status + '</span>' +
            '<div style="font-size:11.5px;color:#5a6573;margin-top:2px">' +
              'TL ' + (u.trust_level || 0) + '  ·  ' + (u.post_count || 0) + ' posts  ·  account ' +
              '<span' + ageWarn + '>' + ageDays + 'd old</span>' +
            '</div>' +
          '</div>' +
          '<a href="/u/' + vpEsc(u.username || '') + '" target="_blank" style="font-size:12px">View profile →</a>' +
        '</div>' +
        '<div style="background:#f7f9fc;padding:10px 12px;border-radius:8px;font-size:13px;line-height:1.5">' +
          '<div><strong>Company:</strong> ' + vpEsc(r.company_name || '—') + '</div>' +
          '<div><strong>License:</strong> ' + vpEsc(r.license_number || '—') + ' (' + vpEsc(r.license_state || '?') + ')' +
            (r.registry_lookup_url ? ' <a href="' + r.registry_lookup_url + '" target="_blank" style="margin-left:6px;font-size:11.5px">verify in registry →</a>' : '') +
            '</div>' +
          (r.note ? '<div style="margin-top:6px"><strong>Applicant note:</strong> ' + vpEsc(r.note) + '</div>' : '') +
          '<div style="margin-top:6px;font-size:11.5px;color:#8b95a3">Submitted ' + (r.submitted_at ? new Date(r.submitted_at).toLocaleString() : '?') +
            (r.decided_by ? '  ·  decided by @' + vpEsc(r.decided_by.username) : '') + '</div>' +
        '</div>' +
        '<div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">' + actions + '</div>' +
      '</div>';
    }).join('');
    // Wire action buttons
    body.querySelectorAll('[data-vp-act]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var act = btn.getAttribute('data-vp-act');
        var uid = btn.getAttribute('data-vp-uid');
        var status = ({approve:'verified',reject:'rejected',revoke:'revoked'})[act];
        if (act === 'info'){
          var msg = prompt('What info do you need from the applicant?');
          if (!msg || !msg.trim()) return;
          post('/admin/coin-engine/verified_pros/' + uid + '/request_info.json', { message: msg })
            .then(function(){ toast('Info request sent', 'win'); })
            .catch(function(e){ toast((e && e.errors && e.errors[0]) || 'Failed', 'err'); });
          return;
        }
        var note = prompt('Optional note for the applicant (visible to them):');
        if (note === null) return; // cancelled
        btn.disabled = true;
        post('/admin/coin-engine/verified_pros/' + uid + '/decide.json', { status: status, note: note })
          .then(function(d){
            toast('Decision recorded', 'win');
            vpLoad(vpState.filter);
            vpLoadStats();
          })
          .catch(function(e){
            toast((e && e.errors && e.errors[0]) || 'Failed', 'err');
            btn.disabled = false;
          });
      });
    });
  }
  function vpLoad(status){
    vpState.filter = status;
    document.querySelectorAll('[data-vp-filter]').forEach(function(b){
      b.classList.toggle('ce-btn-primary', b.getAttribute('data-vp-filter') === status);
    });
    var body = document.getElementById('ce-vp-body');
    if (body) body.innerHTML = '<div class="ce-empty">Loading...</div>';
    get('/admin/coin-engine/verified_pros.json?status=' + encodeURIComponent(status) + '&limit=100')
      .then(function(d){ vpRender(d.records || []); })
      .catch(function(e){
        if (body) body.innerHTML = '<div class="ce-empty">Failed to load. ' + vpEsc((e && e.errors && e.errors[0]) || '') + '</div>';
      });
  }
  function vpLoadStats(){
    get('/admin/coin-engine/verified_pros/stats.json').then(function(d){
      var badge = document.getElementById('ce-vp-badge');
      if (badge && d){
        if (d.pending > 0){ badge.textContent = d.pending; badge.hidden = false; }
        else { badge.hidden = true; }
      }
    }).catch(function(){});
  }
  // Wire filter pills
  document.querySelectorAll('[data-vp-filter]').forEach(function(b){
    b.addEventListener('click', function(){ vpLoad(b.getAttribute('data-vp-filter')); });
  });
  // Auto-load stats on page boot + reload on tab activation
  vpLoadStats();
  document.querySelectorAll('.ce-tab[data-tab="verified_pros"]').forEach(function(t){
    t.addEventListener('click', function(){ vpLoad(vpState.filter); });
  });

})();
</script>

</body>
</html>
