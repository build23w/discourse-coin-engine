<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>$RENO Manual Payments — <%= SiteSetting.title %></title>
  <%= csrf_meta_tags %>
  <style>
    body { margin: 0; background: #f5f7fa; min-height: 100vh; }
    a { color: #d9551f; }
  </style>
</head>
<body>
<%# v0.7.0 — Comprehensive admin payments console.
    Self-contained: inline CSS + JS so it renders cleanly inside the no_ember layout.
    Endpoints used:
      GET  /admin/coin-engine/stats.json                  -- aggregate counts/totals
      GET  /admin/coin-engine/payments.json?page=N        -- recent payments paginated
      GET  /admin/coin-engine/users.json?page=N&q=...     -- all-user browser paginated
      GET  /admin/coin-engine/users/search.json?q=...     -- typeahead user search
      GET  /admin/coin-engine/users/:id/payments.json     -- per-user history
      POST /admin/coin-engine/payments.json               -- create payment
      PUT  /admin/coin-engine/payments/:id/tx.json        -- attach Solana tx signature
%>
<style nonce="<%= csp_nonce_placeholder %>">
  .ce-admin{max-width:1200px;margin:24px auto;padding:0 20px;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Inter,Roboto,Arial,sans-serif;color:#0f1624;-webkit-font-smoothing:antialiased}
  .ce-admin a{color:#d9551f;text-decoration:none;font-weight:600}
  .ce-admin a:hover{text-decoration:underline}
  .ce-admin h1{font-size:24px;font-weight:900;margin:0 0 4px}
  .ce-admin h2{font-size:15px;font-weight:800;margin:0 0 12px;letter-spacing:.2px;text-transform:uppercase;color:#5a6573}
  .ce-admin .ce-sub{color:#5a6573;font-size:13.5px;margin:0 0 24px;line-height:1.5}
  .ce-admin .ce-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
  @media(max-width:760px){.ce-admin .ce-stats{grid-template-columns:repeat(2,1fr)}}
  .ce-stat{background:linear-gradient(135deg,#fff,#f7f9fc);border:1px solid rgba(15,22,36,.08);border-radius:14px;padding:16px}
  .ce-stat-num{font-size:24px;font-weight:900;line-height:1}
  .ce-stat-lbl{font-size:11px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:#5a6573;margin-top:6px}
  .ce-stat-trend{font-size:11px;color:#0f1624;margin-top:4px;opacity:.7}
  .ce-tabs{display:flex;gap:6px;margin-bottom:16px;border-bottom:1px solid rgba(15,22,36,.08);padding-bottom:0;flex-wrap:wrap}
  .ce-wallet-banner{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:12px 16px;border-radius:12px;margin-bottom:14px;font-size:13px}
  .ce-wallet-banner--info{background:linear-gradient(135deg,#eef5ff,#e6f0ff);border:1px solid #c4d8ef;color:#1a3a6e}
  .ce-wallet-banner--warn{background:linear-gradient(135deg,#fff5e8,#ffe8d4);border:1px solid #f0c89a;color:#7a4a0e}
  .ce-wallet-banner code{background:rgba(15,22,36,.08);padding:1px 5px;border-radius:4px;font-size:11.5px}
  .ce-tab{padding:10px 16px;background:transparent;border:none;color:#5a6573;font-weight:700;font-size:13.5px;cursor:pointer;border-radius:8px 8px 0 0;border-bottom:3px solid transparent;margin-bottom:-1px}
  .ce-tab:hover{background:#f7f9fc;color:#0f1624}
  .ce-tab.is-active{background:#fff;color:#d9551f;border-bottom-color:#ff6b35}
  .ce-tab .ce-badge{display:inline-block;background:#ff6b35;color:#fff;font-size:10px;font-weight:800;padding:1px 6px;border-radius:999px;margin-left:6px;vertical-align:1px}
  .ce-panel{background:#fff;border:1px solid rgba(15,22,36,.08);border-radius:0 14px 14px 14px;padding:20px;min-height:300px}
  .ce-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .ce-row label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5a6573;margin-bottom:6px}
  .ce-row .ce-fld{flex:1;min-width:200px}
  .ce-input,.ce-select,.ce-textarea{width:100%;padding:10px 12px;border:1px solid rgba(15,22,36,.15);border-radius:10px;background:#fff;font-size:13.5px;box-sizing:border-box;font-family:inherit}
  .ce-input:focus,.ce-select:focus,.ce-textarea:focus{outline:2px solid #ff6b35;outline-offset:1px;border-color:transparent}
  .ce-textarea{min-height:80px;resize:vertical}
  .ce-btn{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:10px;border:1px solid rgba(15,22,36,.12);background:#fff;color:#0f1624;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s}
  .ce-btn:hover{background:#f7f9fc}
  .ce-btn.ce-btn-primary{background:#ff6b35;color:#fff;border-color:transparent}
  .ce-btn.ce-btn-primary:hover{background:#d9551f}
  .ce-btn.ce-btn-danger{background:#fff;color:#c53030;border-color:rgba(197,48,48,.3)}
  .ce-btn:disabled{opacity:.5;cursor:not-allowed}
  .ce-table{width:100%;border-collapse:collapse;font-size:13px}
  .ce-table th{text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#5a6573;padding:8px 12px;border-bottom:1px solid rgba(15,22,36,.1);font-weight:700}
  .ce-table td{padding:10px 12px;border-bottom:1px solid rgba(15,22,36,.06)}
  .ce-table tr:hover{background:#fcfdff}
  .ce-table .ce-num{text-align:right;font-variant-numeric:tabular-nums}
  .ce-pill{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700;letter-spacing:.3px}
  .ce-pill-sent{background:rgba(76,184,134,.15);color:#1f7a52}
  .ce-pill-pending{background:rgba(255,165,0,.15);color:#9a5b00}
  .ce-pill-mint{background:rgba(118,75,200,.15);color:#5a3a99}
  .ce-pill-tx{background:rgba(15,22,36,.08);color:#0f1624;font-family:ui-monospace,Menlo,monospace;font-size:10.5px}
  .ce-search{position:relative}
  .ce-typeahead{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid rgba(15,22,36,.12);border-radius:10px;margin-top:4px;max-height:240px;overflow-y:auto;box-shadow:0 8px 24px rgba(15,22,36,.1);z-index:100;display:none}
  .ce-typeahead.is-open{display:block}
  .ce-ta-row{padding:9px 12px;cursor:pointer;font-size:13.5px;border-bottom:1px solid rgba(15,22,36,.05)}
  .ce-ta-row:hover,.ce-ta-row.is-focus{background:#fff3eb}
  .ce-ta-row strong{color:#0f1624}
  .ce-ta-row .ce-ta-meta{font-size:11.5px;color:#5a6573;margin-top:2px}
  .ce-pgn{display:flex;justify-content:space-between;align-items:center;margin-top:14px;font-size:12.5px;color:#5a6573}
  .ce-pgn .ce-pgn-btns{display:flex;gap:6px}
  .ce-pgn-btn{padding:6px 12px;border:1px solid rgba(15,22,36,.12);background:#fff;border-radius:8px;cursor:pointer;font-size:12.5px;font-weight:700;color:#0f1624}
  .ce-pgn-btn:disabled{opacity:.4;cursor:not-allowed}
  .ce-toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
  .ce-empty{text-align:center;padding:40px 20px;color:#8b95a3;font-size:13px;font-style:italic}
  .ce-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);padding:10px 18px;border-radius:999px;background:#0f1624;color:#fff;font-size:13px;font-weight:700;z-index:9999;box-shadow:0 12px 30px rgba(15,22,36,.25);transition:opacity .25s ease}
  .ce-toast.ce-toast-err{background:#c53030}
  .ce-toast.ce-toast-win{background:#1f7a52}
  .ce-toast.ce-toast-out{opacity:0}
  .ce-mint-row{padding:14px;background:rgba(118,75,200,.05);border:1px solid rgba(118,75,200,.15);border-radius:12px;margin-bottom:8px}
  .ce-mint-row.ce-mint-done{opacity:.55}
  .ce-mint-meta{font-size:12.5px;color:#5a6573;margin-bottom:8px}
  .ce-mint-input{display:flex;gap:8px;align-items:flex-start}
  .ce-mint-input input{flex:1;font-family:ui-monospace,Menlo,monospace;font-size:12px}
  .ce-form-help{font-size:11.5px;color:#8b95a3;margin-top:4px}
</style>

<div class="ce-admin">
  <h1>$RENO Manual Payments</h1>
  <p class="ce-sub">Issue manual payments, browse the user base, track recent activity, and add Solana transaction signatures after on-chain mint. Admin-only.</p>

  <!-- Stats banner -->
  <section class="ce-stats" id="ce-stats-row">
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-total">—</div><div class="ce-stat-lbl">Total $RENO issued</div><div class="ce-stat-trend" id="ce-stat-total-trend"></div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-payments-week">—</div><div class="ce-stat-lbl">Payments this week</div><div class="ce-stat-trend" id="ce-stat-week-trend"></div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-users-paid">—</div><div class="ce-stat-lbl">Unique users paid</div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-pending-mints">—</div><div class="ce-stat-lbl">Pending Solana mints</div></div>
  </section>

  <!-- Tabs -->
  <div id="ce-wallet-banner" class="ce-wallet-banner" hidden>
    <div>
      <strong id="ce-wallet-banner-title">Backfill custodial wallets</strong>
      <div id="ce-wallet-banner-detail" style="font-size:12px;opacity:.85;margin-top:2px"></div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="ce-btn ce-btn-primary" id="ce-wallet-backfill" hidden>Generate now</button>
    </div>
  </div>

  <nav class="ce-tabs" id="ce-tabs">
    <button class="ce-tab is-active" data-tab="pay">💸 Pay User</button>
    <button class="ce-tab" data-tab="recent">📒 Recent Payments</button>
    <button class="ce-tab" data-tab="users">👥 All Users</button>
    <button class="ce-tab" data-tab="mints">⛓️ Pending Mints <span class="ce-badge" id="ce-mint-badge" hidden></span></button>
    <button class="ce-tab" data-tab="verified_pros">🎖 Verified Pros <span class="ce-badge" id="ce-vp-badge" hidden></span></button>
    <button class="ce-tab" data-tab="withdraw_requests">💰 Withdraw Requests <span class="ce-badge" id="ce-wr-badge" hidden></span></button>
    <button class="ce-tab" data-tab="store">🛍️ Store <span class="ce-badge" id="ce-store-badge" hidden></span></button>
  </nav>

  <!-- Panels -->
  <div class="ce-panel" id="ce-pane-pay">
    <h2>Issue a manual payment</h2>
    <div class="ce-row">
      <div class="ce-fld" style="flex:2;min-width:280px">
        <label>Recipient</label>
        <div class="ce-search">
          <input type="text" class="ce-input" id="ce-pay-q" placeholder="Type a username (e.g. buildersltd)" autocomplete="off">
          <div class="ce-typeahead" id="ce-pay-ta"></div>
        </div>
        <div class="ce-form-help" id="ce-pay-selected" hidden></div>
      </div>
      <div class="ce-fld" style="max-width:160px">
        <label>Amount ($RENO)</label>
        <input type="number" class="ce-input" id="ce-pay-amt" min="1" step="1" placeholder="500">
      </div>
    </div>
    <div class="ce-row">
      <div class="ce-fld">
        <label>Reason</label>
        <select class="ce-select" id="ce-pay-reason">
          <option value="manual">Manual payment</option>
          <option value="airdrop">Airdrop</option>
          <option value="contest_winner">Contest winner</option>
          <option value="featured_review">Featured review</option>
          <option value="quality_post">Quality post bonus</option>
          <option value="bug_bounty">Bug bounty</option>
          <option value="referral">Referral reward</option>
          <option value="event_attendance">Event attendance</option>
          <option value="other">Other (see note)</option>
        </select>
      </div>
      <div class="ce-fld" style="flex:2">
        <label>Note (visible to recipient)</label>
        <input type="text" class="ce-input" id="ce-pay-note" maxlength="280" placeholder="Optional explanation">
      </div>
    </div>
    <div class="ce-row">
      <div class="ce-fld">
        <label>Solana wallet override (optional)</label>
        <input type="text" class="ce-input" id="ce-pay-wallet" placeholder="Leave blank to use recipient's linked wallet" style="font-family:ui-monospace,Menlo,monospace;font-size:12px">
        <div class="ce-form-help">Only fill this if you want to mint to a specific wallet other than the recipient's linked one.</div>
      </div>
    </div>
    <div class="ce-toolbar" style="justify-content:flex-end;margin-top:16px">
      <button class="ce-btn ce-btn-primary" id="ce-pay-submit">Send payment</button>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-recent" hidden>
    <h2>Recent payments</h2>
    <div class="ce-toolbar">
      <input type="text" class="ce-input" id="ce-recent-filter" placeholder="Filter by username or reason..." style="max-width:300px">
      <span style="flex:1"></span>
      <select class="ce-select" id="ce-recent-status" style="max-width:160px">
        <option value="">All status</option>
        <option value="sent">Sent</option>
        <option value="pending_mint">Pending mint</option>
        <option value="minted">Minted</option>
      </select>
    </div>
    <table class="ce-table" id="ce-recent-table">
      <thead><tr><th>When</th><th>Recipient</th><th class="ce-num">Amount</th><th>Reason</th><th>Status</th><th>Tx signature</th></tr></thead>
      <tbody id="ce-recent-body"><tr><td colspan="6" class="ce-empty">Loading...</td></tr></tbody>
    </table>
    <div class="ce-pgn">
      <span id="ce-recent-info">—</span>
      <div class="ce-pgn-btns">
        <button class="ce-pgn-btn" id="ce-recent-prev" disabled>← Prev</button>
        <button class="ce-pgn-btn" id="ce-recent-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-users" hidden>
    <h2>All users</h2>
    <div class="ce-toolbar">
      <input type="text" class="ce-input" id="ce-users-q" placeholder="Search users by name, username, or email..." style="max-width:340px">
      <select class="ce-select" id="ce-users-sort" style="max-width:200px">
        <option value="score_desc">Highest $RENO first</option>
        <option value="score_asc">Lowest $RENO first</option>
        <option value="created_desc">Newest accounts</option>
        <option value="created_asc">Oldest accounts</option>
        <option value="paid_desc">Most paid out (lifetime)</option>
        <option value="paid_recent">Last paid recently</option>
      </select>
    </div>
    <table class="ce-table" id="ce-users-table">
      <thead><tr><th>User</th><th class="ce-num">$RENO score</th><th class="ce-num">Lifetime received</th><th>Last paid</th><th>Wallet</th><th></th></tr></thead>
      <tbody id="ce-users-body"><tr><td colspan="6" class="ce-empty">Loading...</td></tr></tbody>
    </table>
    <div class="ce-pgn">
      <span id="ce-users-info">—</span>
      <div class="ce-pgn-btns">
        <button class="ce-pgn-btn" id="ce-users-prev" disabled>← Prev</button>
        <button class="ce-pgn-btn" id="ce-users-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-mints" hidden>
    <h2>Pending Solana mints</h2>
    <p class="ce-sub">Payments that haven't yet been minted on-chain. Paste the Solana transaction signature once the mint completes to mark the payment as fully settled.</p>
    <div id="ce-mints-body"><div class="ce-empty">Loading...</div></div>
  </div>

  <div class="ce-panel" id="ce-pane-verified_pros" hidden>
    <h2>Verified Pro applications</h2>
    <p class="ce-sub">Approve / reject contractor verification applications. Approved pros get a custom title, a badge, and a sign-up bonus credited automatically.</p>
    <div class="ce-toolbar">
      <button class="ce-btn ce-btn-ghost" data-vp-filter="pending">Pending</button>
      <button class="ce-btn ce-btn-ghost" data-vp-filter="verified">Verified</button>
      <button class="ce-btn ce-btn-ghost" data-vp-filter="rejected">Rejected</button>
      <button class="ce-btn ce-btn-ghost" data-vp-filter="revoked">Revoked</button>
      <button class="ce-btn ce-btn-ghost" data-vp-filter="all">All</button>
    </div>
    <div id="ce-vp-body"><div class="ce-empty">Loading...</div></div>
  </div>

  <div class="ce-panel" id="ce-pane-withdraw_requests" hidden>
    <h2>Withdraw requests</h2>
    <p class="ce-sub">Users with balances below the auto-payout threshold (<%= SiteSetting.coin_engine_solana_min_send_threshold rescue 20_000 %> $RENO) press <em>Request payment</em> in their FAB. Approve to mint manually via the <strong>Pay User</strong> tab; reject to dismiss.</p>
    <div class="ce-toolbar">
      <button class="ce-btn ce-btn-ghost" data-wr-filter="pending">Pending</button>
      <button class="ce-btn ce-btn-ghost" data-wr-filter="approved">Approved</button>
      <button class="ce-btn ce-btn-ghost" data-wr-filter="rejected">Rejected</button>
      <button class="ce-btn ce-btn-ghost" data-wr-filter="cancelled">Cancelled</button>
      <button class="ce-btn ce-btn-ghost" data-wr-filter="all">All</button>
    </div>
    <div id="ce-wr-body"><div class="ce-empty">Loading...</div></div>
  </div>

  <div class="ce-panel" id="ce-pane-store" hidden>
    <h2>Marketplace</h2>
    <p class="ce-sub">Manage NFTs, perks, and bundles users can buy with $RENO or SOL. New items default to <em>active</em>; toggle <em>featured</em> to put them at the top of the grid.</p>

    <div class="ce-toolbar">
      <button class="ce-btn ce-btn-primary" id="ce-store-add-toggle">+ Add item</button>
      <button class="ce-btn ce-btn-ghost" data-store-view="items">Items</button>
      <button class="ce-btn ce-btn-ghost" data-store-view="purchases">Purchases</button>
    </div>

    <div id="ce-store-add-form" hidden style="background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:14px;margin-bottom:12px">
      <h3 style="margin:0 0 10px;font-size:14px">New item</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <label>Name<input type="text" id="ce-store-name" class="ce-input" placeholder="OG Holder NFT"></label>
        <label>Kind<select id="ce-store-kind" class="ce-input">
          <option value="nft">NFT (on-chain)</option>
          <option value="perk">Perk (custom title / badge)</option>
          <option value="bundle">Bundle (perk + $RENO)</option>
        </select></label>
        <label style="grid-column:1/-1">Description<textarea id="ce-store-desc" class="ce-input" rows="2" placeholder="What does the buyer get?"></textarea></label>
        <label>Image URL<input type="text" id="ce-store-image" class="ce-input" placeholder="https://..."></label>
        <label>Mint address (NFT)<input type="text" id="ce-store-mint" class="ce-input" placeholder="optional Solana mint pubkey"></label>
        <label>Price ($RENO)<input type="number" id="ce-store-pr-reno" class="ce-input" min="0" value="0"></label>
        <label>Price (lamports)<input type="number" id="ce-store-pr-sol" class="ce-input" min="0" value="0"></label>
        <label>Supply (0 = unlimited)<input type="number" id="ce-store-supply" class="ce-input" min="0" value="1"></label>
        <label>Traits JSON (perks)<input type="text" id="ce-store-traits" class="ce-input" placeholder='{"title":"OG Holder"}'></label>
        <label style="display:flex;align-items:center;gap:8px"><input type="checkbox" id="ce-store-featured"> Featured</label>
      </div>
      <div style="display:flex;gap:8px;margin-top:12px;justify-content:flex-end">
        <button class="ce-btn ce-btn-ghost" id="ce-store-cancel">Cancel</button>
        <button class="ce-btn ce-btn-primary" id="ce-store-save">Create</button>
      </div>
    </div>

    <div id="ce-store-body"><div class="ce-empty">Loading...</div></div>
  </div>
</div>

<script nonce="<%= csp_nonce_placeholder %>">
(function(){
  if (window.__lfCEAdminLoaded) return; window.__lfCEAdminLoaded = true;

  // ---------- Helpers ----------
  function $(sel, root){ return (root||document).querySelector(sel); }
  function $$(sel, root){ return Array.prototype.slice.call((root||document).querySelectorAll(sel)); }
  function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, function(c){ return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]; }); }
  function fmtN(n){ return Number(n||0).toLocaleString(); }
  function fmtRel(d){ if (!d) return '—'; var t = new Date(d).getTime(); var s = (Date.now()-t)/1000; if (s<60) return Math.round(s)+'s ago'; if (s<3600) return Math.round(s/60)+'m ago'; if (s<86400) return Math.round(s/3600)+'h ago'; var days = Math.round(s/86400); if (days<60) return days+'d ago'; return new Date(t).toLocaleDateString(); }
  function fmtFull(d){ if (!d) return '—'; var t = new Date(d); return t.toLocaleString(); }
  function csrf(){ var m = document.querySelector('meta[name="csrf-token"]'); return m ? m.getAttribute('content') : ''; }
  function get(url){ return fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function post(url, body){ return fetch(url, { method: 'POST', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() }, body: JSON.stringify(body || {}) }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function put(url, body){ return fetch(url, { method: 'PUT', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() }, body: JSON.stringify(body || {}) }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function toast(msg, kind){ var t = document.createElement('div'); t.className = 'ce-toast' + (kind ? ' ce-toast-' + kind : ''); t.textContent = msg; document.body.appendChild(t); setTimeout(function(){ t.classList.add('ce-toast-out'); }, 2500); setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, 3000); }

  // ---------- Stats banner ----------
  function loadStats(){
    get('/admin/coin-engine/stats.json').then(function(s){
      $('#ce-stat-total').textContent = fmtN(s.total_distributed || 0);
      $('#ce-stat-payments-week').textContent = fmtN(s.payments_week || 0);
      $('#ce-stat-users-paid').textContent = fmtN(s.unique_users_paid || 0);
      $('#ce-stat-pending-mints').textContent = fmtN(s.pending_mints || 0);
      if (s.payments_today) { $('#ce-stat-week-trend').textContent = '+' + s.payments_today + ' today'; }
      if (s.pending_mints && s.pending_mints > 0){ var b = $('#ce-mint-badge'); b.hidden = false; b.textContent = s.pending_mints; }
    }).catch(function(){ /* stats endpoint optional */ });
  }

  // ---------- Tabs ----------
  $$('.ce-tab').forEach(function(b){
    b.addEventListener('click', function(){
      $$('.ce-tab').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      var k = b.getAttribute('data-tab');
      ['pay','recent','users','mints','verified_pros','withdraw_requests','store'].forEach(function(t){
        var pane = $('#ce-pane-' + t);
        if (pane) pane.hidden = (t !== k);
      });
      if (k === 'recent' && !state.recentLoaded) loadRecent();
      if (k === 'users'  && !state.usersLoaded)  loadUsers();
      if (k === 'mints'  && !state.mintsLoaded)  loadMints();
      if (k === 'withdraw_requests') loadWithdrawRequests(wrState.filter);
      if (k === 'store') loadStoreItems();
    });
  });

  // ---------- Withdraw Requests tab (v0.11.0) ----------
  var wrState = { filter: 'pending' };
  function loadWithdrawRequestStats(){
    get('/admin/coin-engine/withdraw_requests/stats.json').then(function(d){
      var b = $('#ce-wr-badge');
      if (b && d && d.pending > 0){ b.hidden = false; b.textContent = d.pending; }
    }).catch(function(){});
  }
  function loadWithdrawRequests(status){
    wrState.filter = status;
    $$('[data-wr-filter]').forEach(function(b){
      b.classList.toggle('ce-btn-primary', b.getAttribute('data-wr-filter') === status);
    });
    var body = $('#ce-wr-body');
    if (body) body.innerHTML = '<div class="ce-empty">Loading...</div>';
    var q = (status === 'all') ? '' : ('?status=' + encodeURIComponent(status) + '&limit=100');
    get('/admin/coin-engine/withdraw_requests.json' + q).then(function(d){
      renderWithdrawRequests(d.records || []);
    }).catch(function(e){
      if (body) body.innerHTML = '<div class="ce-empty">Failed to load. ' + esc((e && e.errors && e.errors[0]) || '') + '</div>';
    });
  }
  function renderWithdrawRequests(records){
    var body = $('#ce-wr-body');
    if (!body) return;
    if (records.length === 0){
      body.innerHTML = '<div class="ce-empty">No withdraw requests in this state.</div>';
      return;
    }
    body.innerHTML = records.map(function(r){
      var u = r.user || {};
      var pillClass = ({pending:'ce-pill-sent',approved:'ce-pill-mint',rejected:'ce-pill',cancelled:'ce-pill'})[r.status] || 'ce-pill';
      var actions = '';
      if (r.status === 'pending'){
        actions =
          '<button class="ce-btn ce-btn-primary" data-wr-act="approve" data-wr-id="' + r.id + '">Approve</button>' +
          '<button class="ce-btn" data-wr-act="reject" data-wr-id="' + r.id + '">Reject</button>' +
          '<a class="ce-btn ce-btn-ghost" href="#pay" data-wr-payto="' + esc(u.username || '') + '" data-wr-amount="' + r.amount + '" data-wr-wallet="' + esc(r.wallet_address || '') + '">Pay now &rarr;</a>';
      }
      return '<div class="ce-card" style="margin-bottom:10px;padding:14px;border-radius:10px;background:#fff;border:1px solid rgba(0,0,0,.08)">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:8px">' +
          '<div>' +
            '<strong style="font-size:14.5px">@' + esc(u.username || '?') + '</strong>' +
            '<span class="ce-pill ' + pillClass + '" style="margin-left:8px">' + r.status + '</span>' +
            '<div style="font-size:11.5px;color:#5a6573;margin-top:2px">' +
              'TL ' + (u.trust_level || 0) + '  ·  ' + (u.post_count || 0) + ' posts  ·  ' + fmtRel(r.created_at) +
            '</div>' +
          '</div>' +
          '<a href="/u/' + esc(u.username || '') + '" target="_blank" style="font-size:12px">View profile &rarr;</a>' +
        '</div>' +
        '<div style="background:#f7f9fc;padding:10px 12px;border-radius:8px;font-size:13px;line-height:1.5">' +
          '<div><strong>Amount:</strong> ' + fmtN(r.amount) + ' $RENO</div>' +
          '<div><strong>Wallet:</strong> <code style="font-size:11.5px">' + esc(r.wallet_address || '—') + '</code></div>' +
          (r.user_note ? '<div style="margin-top:6px"><strong>User note:</strong> ' + esc(r.user_note) + '</div>' : '') +
          (r.admin_note ? '<div style="margin-top:6px"><strong>Admin note:</strong> ' + esc(r.admin_note) + '</div>' : '') +
          (r.decided_by ? '<div style="margin-top:6px;font-size:11.5px;color:#8b95a3">Decided by @' + esc(r.decided_by.username) + ' · ' + fmtRel(r.decided_at) + '</div>' : '') +
        '</div>' +
        (actions ? '<div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">' + actions + '</div>' : '') +
        '</div>';
    }).join('');
    body.querySelectorAll('[data-wr-act]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var act = btn.getAttribute('data-wr-act');
        var id = btn.getAttribute('data-wr-id');
        var note = prompt(act === 'approve' ? 'Optional note for the user:' : 'Reason for rejecting (visible to user):');
        if (note === null) return;
        btn.disabled = true;
        post('/admin/coin-engine/withdraw_requests/' + id + '/decide.json', {
          status: (act === 'approve' ? 'approved' : 'rejected'),
          admin_note: note
        }).then(function(){
          toast('Request ' + (act === 'approve' ? 'approved' : 'rejected'), 'win');
          loadWithdrawRequests(wrState.filter);
          loadWithdrawRequestStats();

  // ---------- Store admin (v0.12.0) ----------
  var storeState = { view: 'items' };
  function loadStoreItems(){
    storeState.view = 'items';
    document.querySelectorAll('[data-store-view]').forEach(function(b){
      b.classList.toggle('ce-btn-primary', b.getAttribute('data-store-view') === 'items');
    });
    var body = $('#ce-store-body');
    if (body) body.innerHTML = '<div class="ce-empty">Loading...</div>';
    get('/admin/coin-engine/store/items.json').then(function(d){ renderStoreItems(d.items || []); })
      .catch(function(e){ body.innerHTML = '<div class="ce-empty">Failed to load: ' + esc((e && e.errors && e.errors[0]) || '') + '</div>'; });
  }
  function loadStorePurchases(){
    storeState.view = 'purchases';
    document.querySelectorAll('[data-store-view]').forEach(function(b){
      b.classList.toggle('ce-btn-primary', b.getAttribute('data-store-view') === 'purchases');
    });
    var body = $('#ce-store-body');
    body.innerHTML = '<div class="ce-empty">Loading...</div>';
    get('/admin/coin-engine/store/purchases.json').then(function(d){ renderStorePurchases(d.purchases || []); })
      .catch(function(e){ body.innerHTML = '<div class="ce-empty">Failed to load: ' + esc((e && e.errors && e.errors[0]) || '') + '</div>'; });
  }
  function renderStoreItems(items){
    var body = $('#ce-store-body');
    if (!items.length){ body.innerHTML = '<div class="ce-empty">No items yet. Click <strong>+ Add item</strong> to create your first.</div>'; return; }
    body.innerHTML = items.map(function(it){
      var thumb = it.image_url ? '<img src="'+esc(it.image_url)+'" style="width:60px;height:60px;border-radius:8px;object-fit:cover">' : '<div style="width:60px;height:60px;border-radius:8px;background:#f7f9fc;display:flex;align-items:center;justify-content:center;font-size:24px;opacity:.4">'+(it.kind==='nft'?'🖼':'🎁')+'</div>';
      var price = (it.price_reno > 0 ? fmtN(it.price_reno) + ' $RENO' : '') + (it.price_sol_lamports > 0 ? (it.price_reno > 0 ? ' · ' : '') + (it.price_sol_lamports / 1e9).toFixed(3) + ' SOL' : '');
      return '<div class="ce-card" style="margin-bottom:10px;padding:12px;display:flex;gap:12px;align-items:center;background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:10px">' +
        thumb +
        '<div style="flex:1;min-width:0">'+
          '<strong>'+esc(it.name)+'</strong> <span class="ce-pill" style="margin-left:6px">'+esc(it.kind)+'</span>'+
          (it.featured ? ' <span class="ce-pill ce-pill-mint">FEATURED</span>' : '')+
          (!it.active ? ' <span class="ce-pill" style="background:#f0f1f5;color:#5a6573">INACTIVE</span>' : '')+
          '<div style="font-size:11.5px;color:#5a6573;margin-top:2px">'+esc(price || 'Free')+(it.supply > 0 ? '  ·  '+it.sold_count+'/'+it.supply+' sold' : '  ·  unlimited')+'</div>'+
        '</div>'+
        '<div style="display:flex;gap:6px">'+
          '<button class="ce-btn ce-btn-ghost" data-store-toggle="'+it.id+'" data-store-active="'+(it.active?'1':'0')+'">'+(it.active?'Deactivate':'Activate')+'</button>'+
          '<button class="ce-btn ce-btn-ghost" data-store-feature="'+it.id+'" data-store-featured="'+(it.featured?'1':'0')+'">'+(it.featured?'Unfeature':'Feature')+'</button>'+
        '</div>'+
      '</div>';
    }).join('');
    body.querySelectorAll('[data-store-toggle]').forEach(function(b){
      b.addEventListener('click', function(){
        var id = b.getAttribute('data-store-toggle');
        var newActive = b.getAttribute('data-store-active') === '0';
        put('/admin/coin-engine/store/items/' + id + '.json', { active: newActive }).then(loadStoreItems)
          .catch(function(e){ toast((e && e.errors && e.errors[0]) || 'Failed', 'err'); });
      });
    });
    body.querySelectorAll('[data-store-feature]').forEach(function(b){
      b.addEventListener('click', function(){
        var id = b.getAttribute('data-store-feature');
        var newFeat = b.getAttribute('data-store-featured') === '0';
        put('/admin/coin-engine/store/items/' + id + '.json', { featured: newFeat }).then(loadStoreItems)
          .catch(function(e){ toast((e && e.errors && e.errors[0]) || 'Failed', 'err'); });
      });
    });
  }
  function renderStorePurchases(purchases){
    var body = $('#ce-store-body');
    if (!purchases.length){ body.innerHTML = '<div class="ce-empty">No purchases yet.</div>'; return; }
    body.innerHTML = purchases.map(function(p){
      var u = p.user || {};
      var item = p.item || {};
      var price = p.currency === 'reno' ? (fmtN(p.amount_paid) + ' $RENO') : ((p.amount_paid / 1e9).toFixed(4) + ' SOL');
      var statusPill = ({pending:'ce-pill-sent',paid:'ce-pill-mint',fulfilled:'ce-pill-mint',failed:'ce-pill',refunded:'ce-pill',cancelled:'ce-pill'})[p.status] || 'ce-pill';
      var actions = '';
      if (p.status === 'paid')   actions += '<button class="ce-btn ce-btn-primary" data-store-fulfill="'+p.id+'">Fulfill</button>';
      if (p.status !== 'refunded' && p.status !== 'cancelled') actions += ' <button class="ce-btn ce-btn-ghost" data-store-refund="'+p.id+'">Refund</button>';
      return '<div class="ce-card" style="margin-bottom:10px;padding:12px;background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:10px">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">' +
          '<div>' +
            '<strong>@' + esc(u.username || '?') + '</strong>' +
            '<span class="ce-pill ' + statusPill + '" style="margin-left:6px">'+ esc(p.status) +'</span>' +
            '<div style="font-size:11.5px;color:#5a6573;margin-top:2px">'+ esc(item.name || ('Order #' + p.id)) +' · '+ esc(price) +' · '+ fmtRel(p.created_at) +'</div>' +
            (p.tx_signature ? '<div style="font-size:10.5px;font-family:ui-monospace,Menlo,monospace;color:#8b95a3;margin-top:2px">tx: '+ esc(p.tx_signature.slice(0,12)) +'…</div>' : '') +
          '</div>' +
          '<div style="display:flex;gap:6px">'+ actions +'</div>' +
        '</div>' +
      '</div>';
    }).join('');
    body.querySelectorAll('[data-store-fulfill]').forEach(function(b){
      b.addEventListener('click', function(){
        post('/admin/coin-engine/store/purchases/' + b.getAttribute('data-store-fulfill') + '/fulfill.json', {})
          .then(function(){ toast('Marked fulfilled', 'win'); loadStorePurchases(); })
          .catch(function(e){ toast((e && e.errors && e.errors[0]) || 'Failed', 'err'); });
      });
    });
    body.querySelectorAll('[data-store-refund]').forEach(function(b){
      b.addEventListener('click', function(){
        if (!confirm('Refund this purchase? $RENO will be credited back; supply slot will be returned.')) return;
        post('/admin/coin-engine/store/purchases/' + b.getAttribute('data-store-refund') + '/refund.json', {})
          .then(function(){ toast('Refunded', 'win'); loadStorePurchases(); })
          .catch(function(e){ toast((e && e.errors && e.errors[0]) || 'Failed', 'err'); });
      });
    });
  }
  // Wire view-switcher + add-item form
  $$('[data-store-view]').forEach(function(b){
    b.addEventListener('click', function(){
      var v = b.getAttribute('data-store-view');
      if (v === 'items') loadStoreItems(); else loadStorePurchases();
    });
  });
  if ($('#ce-store-add-toggle')){
    $('#ce-store-add-toggle').addEventListener('click', function(){
      var f = $('#ce-store-add-form'); f.hidden = !f.hidden;
    });
  }
  if ($('#ce-store-cancel')){
    $('#ce-store-cancel').addEventListener('click', function(){ $('#ce-store-add-form').hidden = true; });
  }
  if ($('#ce-store-save')){
    $('#ce-store-save').addEventListener('click', function(){
      var btn = $('#ce-store-save'); btn.disabled = true;
      var traits = $('#ce-store-traits').value.trim();
      if (traits){
        try { JSON.parse(traits); } catch(e){ toast('Traits JSON is invalid', 'err'); btn.disabled = false; return; }
      }
      var body = {
        name:               $('#ce-store-name').value,
        kind:               $('#ce-store-kind').value,
        description:        $('#ce-store-desc').value,
        image_url:          $('#ce-store-image').value,
        mint_address:       $('#ce-store-mint').value,
        price_reno:         parseInt($('#ce-store-pr-reno').value, 10) || 0,
        price_sol_lamports: parseInt($('#ce-store-pr-sol').value,  10) || 0,
        supply:             parseInt($('#ce-store-supply').value,  10) || 0,
        traits_json:        traits || null,
        featured:           $('#ce-store-featured').checked
      };
      post('/admin/coin-engine/store/items.json', body).then(function(){
        toast('Item created', 'win');
        $('#ce-store-add-form').hidden = true;
        // Reset form
        ['ce-store-name','ce-store-desc','ce-store-image','ce-store-mint','ce-store-traits'].forEach(function(id){ $('#'+id).value = ''; });
        $('#ce-store-pr-reno').value = '0'; $('#ce-store-pr-sol').value = '0'; $('#ce-store-supply').value = '1';
        $('#ce-store-featured').checked = false;
        loadStoreItems();
      }).catch(function(e){
        toast((e && e.errors && e.errors[0]) || 'Failed to save', 'err');
      }).finally(function(){ btn.disabled = false; });
    });
  }
        }).catch(function(e){
          toast((e && e.errors && e.errors[0]) || 'Failed', 'err');
          btn.disabled = false;
        });
      });
    });
    body.querySelectorAll('[data-wr-payto]').forEach(function(a){
      a.addEventListener('click', function(e){
        e.preventDefault();
        var uname = a.getAttribute('data-wr-payto');
        var amount = a.getAttribute('data-wr-amount');
        var wallet = a.getAttribute('data-wr-wallet');
        $$('.ce-tab[data-tab="pay"]')[0].click();
        if (payQ){ payQ.value = uname; payQ.dispatchEvent(new Event('input')); }
        var amt = $('#ce-pay-amount'); if (amt) amt.value = amount;
        var ov  = $('#ce-pay-wallet'); if (ov && wallet) ov.value = wallet;
      });
    });
