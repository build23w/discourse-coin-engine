<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>$RENO Manual Payments — <%= SiteSetting.title %></title>
  <%= csrf_meta_tags %>
  <style>
    body { margin: 0; background: #f5f7fa; min-height: 100vh; }
    a { color: #d9551f; }
  </style>
</head>
<body>
<%# v0.7.0 — Comprehensive admin payments console.
    Self-contained: inline CSS + JS so it renders cleanly inside the no_ember layout.
    Endpoints used:
      GET  /admin/coin-engine/stats.json                  -- aggregate counts/totals
      GET  /admin/coin-engine/payments.json?page=N        -- recent payments paginated
      GET  /admin/coin-engine/users.json?page=N&q=...     -- all-user browser paginated
      GET  /admin/coin-engine/users/search.json?q=...     -- typeahead user search
      GET  /admin/coin-engine/users/:id/payments.json     -- per-user history
      POST /admin/coin-engine/payments.json               -- create payment
      PUT  /admin/coin-engine/payments/:id/tx.json        -- attach Solana tx signature
%>
<style nonce="<%= csp_nonce_placeholder %>">
  .ce-admin{max-width:1200px;margin:24px auto;padding:0 20px;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Inter,Roboto,Arial,sans-serif;color:#0f1624;-webkit-font-smoothing:antialiased}
  .ce-admin a{color:#d9551f;text-decoration:none;font-weight:600}
  .ce-admin a:hover{text-decoration:underline}
  .ce-admin h1{font-size:24px;font-weight:900;margin:0 0 4px}
  .ce-admin h2{font-size:15px;font-weight:800;margin:0 0 12px;letter-spacing:.2px;text-transform:uppercase;color:#5a6573}
  .ce-admin .ce-sub{color:#5a6573;font-size:13.5px;margin:0 0 24px;line-height:1.5}
  .ce-admin .ce-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
  @media(max-width:760px){.ce-admin .ce-stats{grid-template-columns:repeat(2,1fr)}}
  .ce-stat{background:linear-gradient(135deg,#fff,#f7f9fc);border:1px solid rgba(15,22,36,.08);border-radius:14px;padding:16px}
  .ce-stat-num{font-size:24px;font-weight:900;line-height:1}
  .ce-stat-lbl{font-size:11px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:#5a6573;margin-top:6px}
  .ce-stat-trend{font-size:11px;color:#0f1624;margin-top:4px;opacity:.7}
  .ce-tabs{display:flex;gap:6px;margin-bottom:16px;border-bottom:1px solid rgba(15,22,36,.08);padding-bottom:0;flex-wrap:wrap}
  .ce-tab{padding:10px 16px;background:transparent;border:none;color:#5a6573;font-weight:700;font-size:13.5px;cursor:pointer;border-radius:8px 8px 0 0;border-bottom:3px solid transparent;margin-bottom:-1px}
  .ce-tab:hover{background:#f7f9fc;color:#0f1624}
  .ce-tab.is-active{background:#fff;color:#d9551f;border-bottom-color:#ff6b35}
  .ce-tab .ce-badge{display:inline-block;background:#ff6b35;color:#fff;font-size:10px;font-weight:800;padding:1px 6px;border-radius:999px;margin-left:6px;vertical-align:1px}
  .ce-panel{background:#fff;border:1px solid rgba(15,22,36,.08);border-radius:0 14px 14px 14px;padding:20px;min-height:300px}
  .ce-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .ce-row label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5a6573;margin-bottom:6px}
  .ce-row .ce-fld{flex:1;min-width:200px}
  .ce-input,.ce-select,.ce-textarea{width:100%;padding:10px 12px;border:1px solid rgba(15,22,36,.15);border-radius:10px;background:#fff;font-size:13.5px;box-sizing:border-box;font-family:inherit}
  .ce-input:focus,.ce-select:focus,.ce-textarea:focus{outline:2px solid #ff6b35;outline-offset:1px;border-color:transparent}
  .ce-textarea{min-height:80px;resize:vertical}
  .ce-btn{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:10px;border:1px solid rgba(15,22,36,.12);background:#fff;color:#0f1624;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s}
  .ce-btn:hover{background:#f7f9fc}
  .ce-btn.ce-btn-primary{background:#ff6b35;color:#fff;border-color:transparent}
  .ce-btn.ce-btn-primary:hover{background:#d9551f}
  .ce-btn.ce-btn-danger{background:#fff;color:#c53030;border-color:rgba(197,48,48,.3)}
  .ce-btn:disabled{opacity:.5;cursor:not-allowed}
  .ce-table{width:100%;border-collapse:collapse;font-size:13px}
  .ce-table th{text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#5a6573;padding:8px 12px;border-bottom:1px solid rgba(15,22,36,.1);font-weight:700}
  .ce-table td{padding:10px 12px;border-bottom:1px solid rgba(15,22,36,.06)}
  .ce-table tr:hover{background:#fcfdff}
  .ce-table .ce-num{text-align:right;font-variant-numeric:tabular-nums}
  .ce-pill{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700;letter-spacing:.3px}
  .ce-pill-sent{background:rgba(76,184,134,.15);color:#1f7a52}
  .ce-pill-pending{background:rgba(255,165,0,.15);color:#9a5b00}
  .ce-pill-mint{background:rgba(118,75,200,.15);color:#5a3a99}
  .ce-pill-tx{background:rgba(15,22,36,.08);color:#0f1624;font-family:ui-monospace,Menlo,monospace;font-size:10.5px}
  .ce-search{position:relative}
  .ce-typeahead{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid rgba(15,22,36,.12);border-radius:10px;margin-top:4px;max-height:240px;overflow-y:auto;box-shadow:0 8px 24px rgba(15,22,36,.1);z-index:100;display:none}
  .ce-typeahead.is-open{display:block}
  .ce-ta-row{padding:9px 12px;cursor:pointer;font-size:13.5px;border-bottom:1px solid rgba(15,22,36,.05)}
  .ce-ta-row:hover,.ce-ta-row.is-focus{background:#fff3eb}
  .ce-ta-row strong{color:#0f1624}
  .ce-ta-row .ce-ta-meta{font-size:11.5px;color:#5a6573;margin-top:2px}
  .ce-pgn{display:flex;justify-content:space-between;align-items:center;margin-top:14px;font-size:12.5px;color:#5a6573}
  .ce-pgn .ce-pgn-btns{display:flex;gap:6px}
  .ce-pgn-btn{padding:6px 12px;border:1px solid rgba(15,22,36,.12);background:#fff;border-radius:8px;cursor:pointer;font-size:12.5px;font-weight:700;color:#0f1624}
  .ce-pgn-btn:disabled{opacity:.4;cursor:not-allowed}
  .ce-toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
  .ce-empty{text-align:center;padding:40px 20px;color:#8b95a3;font-size:13px;font-style:italic}
  .ce-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);padding:10px 18px;border-radius:999px;background:#0f1624;color:#fff;font-size:13px;font-weight:700;z-index:9999;box-shadow:0 12px 30px rgba(15,22,36,.25);transition:opacity .25s ease}
  .ce-toast.ce-toast-err{background:#c53030}
  .ce-toast.ce-toast-win{background:#1f7a52}
  .ce-toast.ce-toast-out{opacity:0}
  .ce-mint-row{padding:14px;background:rgba(118,75,200,.05);border:1px solid rgba(118,75,200,.15);border-radius:12px;margin-bottom:8px}
  .ce-mint-row.ce-mint-done{opacity:.55}
  .ce-mint-meta{font-size:12.5px;color:#5a6573;margin-bottom:8px}
  .ce-mint-input{display:flex;gap:8px;align-items:flex-start}
  .ce-mint-input input{flex:1;font-family:ui-monospace,Menlo,monospace;font-size:12px}
  .ce-form-help{font-size:11.5px;color:#8b95a3;margin-top:4px}
</style>

<div class="ce-admin">
  <h1>$RENO Manual Payments</h1>
  <p class="ce-sub">Issue manual payments, browse the user base, track recent activity, and add Solana transaction signatures after on-chain mint. Admin-only.</p>

  <!-- Stats banner -->
  <section class="ce-stats" id="ce-stats-row">
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-total">—</div><div class="ce-stat-lbl">Total $RENO issued</div><div class="ce-stat-trend" id="ce-stat-total-trend"></div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-payments-week">—</div><div class="ce-stat-lbl">Payments this week</div><div class="ce-stat-trend" id="ce-stat-week-trend"></div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-users-paid">—</div><div class="ce-stat-lbl">Unique users paid</div></div>
    <div class="ce-stat"><div class="ce-stat-num" id="ce-stat-pending-mints">—</div><div class="ce-stat-lbl">Pending Solana mints</div></div>
  </section>

  <!-- Tabs -->
  <nav class="ce-tabs" id="ce-tabs">
    <button class="ce-tab is-active" data-tab="pay">💸 Pay User</button>
    <button class="ce-tab" data-tab="recent">📒 Recent Payments</button>
    <button class="ce-tab" data-tab="users">👥 All Users</button>
    <button class="ce-tab" data-tab="mints">⛓️ Pending Mints <span class="ce-badge" id="ce-mint-badge" hidden></span></button>
  </nav>

  <!-- Panels -->
  <div class="ce-panel" id="ce-pane-pay">
    <h2>Issue a manual payment</h2>
    <div class="ce-row">
      <div class="ce-fld" style="flex:2;min-width:280px">
        <label>Recipient</label>
        <div class="ce-search">
          <input type="text" class="ce-input" id="ce-pay-q" placeholder="Type a username (e.g. buildersltd)" autocomplete="off">
          <div class="ce-typeahead" id="ce-pay-ta"></div>
        </div>
        <div class="ce-form-help" id="ce-pay-selected" hidden></div>
      </div>
      <div class="ce-fld" style="max-width:160px">
        <label>Amount ($RENO)</label>
        <input type="number" class="ce-input" id="ce-pay-amt" min="1" step="1" placeholder="500">
      </div>
    </div>
    <div class="ce-row">
      <div class="ce-fld">
        <label>Reason</label>
        <select class="ce-select" id="ce-pay-reason">
          <option value="manual">Manual payment</option>
          <option value="airdrop">Airdrop</option>
          <option value="contest_winner">Contest winner</option>
          <option value="featured_review">Featured review</option>
          <option value="quality_post">Quality post bonus</option>
          <option value="bug_bounty">Bug bounty</option>
          <option value="referral">Referral reward</option>
          <option value="event_attendance">Event attendance</option>
          <option value="other">Other (see note)</option>
        </select>
      </div>
      <div class="ce-fld" style="flex:2">
        <label>Note (visible to recipient)</label>
        <input type="text" class="ce-input" id="ce-pay-note" maxlength="280" placeholder="Optional explanation">
      </div>
    </div>
    <div class="ce-row">
      <div class="ce-fld">
        <label>Solana wallet override (optional)</label>
        <input type="text" class="ce-input" id="ce-pay-wallet" placeholder="Leave blank to use recipient's linked wallet" style="font-family:ui-monospace,Menlo,monospace;font-size:12px">
        <div class="ce-form-help">Only fill this if you want to mint to a specific wallet other than the recipient's linked one.</div>
      </div>
    </div>
    <div class="ce-toolbar" style="justify-content:flex-end;margin-top:16px">
      <button class="ce-btn ce-btn-primary" id="ce-pay-submit">Send payment</button>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-recent" hidden>
    <h2>Recent payments</h2>
    <div class="ce-toolbar">
      <input type="text" class="ce-input" id="ce-recent-filter" placeholder="Filter by username or reason..." style="max-width:300px">
      <span style="flex:1"></span>
      <select class="ce-select" id="ce-recent-status" style="max-width:160px">
        <option value="">All status</option>
        <option value="sent">Sent</option>
        <option value="pending_mint">Pending mint</option>
        <option value="minted">Minted</option>
      </select>
    </div>
    <table class="ce-table" id="ce-recent-table">
      <thead><tr><th>When</th><th>Recipient</th><th class="ce-num">Amount</th><th>Reason</th><th>Status</th><th>Tx signature</th></tr></thead>
      <tbody id="ce-recent-body"><tr><td colspan="6" class="ce-empty">Loading...</td></tr></tbody>
    </table>
    <div class="ce-pgn">
      <span id="ce-recent-info">—</span>
      <div class="ce-pgn-btns">
        <button class="ce-pgn-btn" id="ce-recent-prev" disabled>← Prev</button>
        <button class="ce-pgn-btn" id="ce-recent-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-users" hidden>
    <h2>All users</h2>
    <div class="ce-toolbar">
      <input type="text" class="ce-input" id="ce-users-q" placeholder="Search users by name, username, or email..." style="max-width:340px">
      <select class="ce-select" id="ce-users-sort" style="max-width:200px">
        <option value="score_desc">Highest $RENO first</option>
        <option value="score_asc">Lowest $RENO first</option>
        <option value="created_desc">Newest accounts</option>
        <option value="created_asc">Oldest accounts</option>
        <option value="paid_desc">Most paid out (lifetime)</option>
        <option value="paid_recent">Last paid recently</option>
      </select>
    </div>
    <table class="ce-table" id="ce-users-table">
      <thead><tr><th>User</th><th class="ce-num">$RENO score</th><th class="ce-num">Lifetime received</th><th>Last paid</th><th>Wallet</th><th></th></tr></thead>
      <tbody id="ce-users-body"><tr><td colspan="6" class="ce-empty">Loading...</td></tr></tbody>
    </table>
    <div class="ce-pgn">
      <span id="ce-users-info">—</span>
      <div class="ce-pgn-btns">
        <button class="ce-pgn-btn" id="ce-users-prev" disabled>← Prev</button>
        <button class="ce-pgn-btn" id="ce-users-next" disabled>Next →</button>
      </div>
    </div>
  </div>

  <div class="ce-panel" id="ce-pane-mints" hidden>
    <h2>Pending Solana mints</h2>
    <p class="ce-sub">Payments that haven't yet been minted on-chain. Paste the Solana transaction signature once the mint completes to mark the payment as fully settled.</p>
    <div id="ce-mints-body"><div class="ce-empty">Loading...</div></div>
  </div>
</div>

<script nonce="<%= csp_nonce_placeholder %>">
(function(){
  if (window.__lfCEAdminLoaded) return; window.__lfCEAdminLoaded = true;

  // ---------- Helpers ----------
  function $(sel, root){ return (root||document).querySelector(sel); }
  function $$(sel, root){ return Array.prototype.slice.call((root||document).querySelectorAll(sel)); }
  function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, function(c){ return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]; }); }
  function fmtN(n){ return Number(n||0).toLocaleString(); }
  function fmtRel(d){ if (!d) return '—'; var t = new Date(d).getTime(); var s = (Date.now()-t)/1000; if (s<60) return Math.round(s)+'s ago'; if (s<3600) return Math.round(s/60)+'m ago'; if (s<86400) return Math.round(s/3600)+'h ago'; var days = Math.round(s/86400); if (days<60) return days+'d ago'; return new Date(t).toLocaleDateString(); }
  function fmtFull(d){ if (!d) return '—'; var t = new Date(d); return t.toLocaleString(); }
  function csrf(){ var m = document.querySelector('meta[name="csrf-token"]'); return m ? m.getAttribute('content') : ''; }
  function get(url){ return fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function post(url, body){ return fetch(url, { method: 'POST', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() }, body: JSON.stringify(body || {}) }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function put(url, body){ return fetch(url, { method: 'PUT', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() }, body: JSON.stringify(body || {}) }).then(function(r){ return r.json().then(function(j){ return r.ok ? j : Promise.reject(j); }); }); }
  function toast(msg, kind){ var t = document.createElement('div'); t.className = 'ce-toast' + (kind ? ' ce-toast-' + kind : ''); t.textContent = msg; document.body.appendChild(t); setTimeout(function(){ t.classList.add('ce-toast-out'); }, 2500); setTimeout(function(){ if (t.parentNode) t.parentNode.removeChild(t); }, 3000); }

  // ---------- Stats banner ----------
  function loadStats(){
    get('/admin/coin-engine/stats.json').then(function(s){
      $('#ce-stat-total').textContent = fmtN(s.total_distributed || 0);
      $('#ce-stat-payments-week').textContent = fmtN(s.payments_week || 0);
      $('#ce-stat-users-paid').textContent = fmtN(s.unique_users_paid || 0);
      $('#ce-stat-pending-mints').textContent = fmtN(s.pending_mints || 0);
      if (s.payments_today) { $('#ce-stat-week-trend').textContent = '+' + s.payments_today + ' today'; }
      if (s.pending_mints && s.pending_mints > 0){ var b = $('#ce-mint-badge'); b.hidden = false; b.textContent = s.pending_mints; }
    }).catch(function(){ /* stats endpoint optional */ });
  }

  // ---------- Tabs ----------
  $$('.ce-tab').forEach(function(b){
    b.addEventListener('click', function(){
      $$('.ce-tab').forEach(function(x){ x.classList.remove('is-active'); });
      b.classList.add('is-active');
      var k = b.getAttribute('data-tab');
      ['pay','recent','users','mints'].forEach(function(t){
        $('#ce-pane-' + t).hidden = (t !== k);
      });
      if (k === 'recent' && !state.recentLoaded) loadRecent();
      if (k === 'users'  && !state.usersLoaded)  loadUsers();
      if (k === 'mints'  && !state.mintsLoaded)  loadMints();
    });
  });

  var state = { selectedUser: null, recentPage: 1, usersPage: 1, recentLoaded: false, usersLoaded: false, mintsLoaded: false };

  // ---------- Pay tab: typeahead ----------
  var payQ = $('#ce-pay-q'), payTA = $('#ce-pay-ta'), payTimer = null;
  payQ.addEventListener('input', function(){
    clearTimeout(payTimer);
    var q = payQ.value.trim();
    if (q.length < 2){ payTA.classList.remove('is-open'); payTA.innerHTML = ''; return; }
    payTimer = setTimeout(function(){
      get('/admin/coin-engine/users/search.json?q=' + encodeURIComponent(q)).then(function(d){
        var rows = (d.users || []).map(function(u){
          return '<div class="ce-ta-row" data-uid="' + u.id + '" data-uname="' + esc(u.username) + '" data-wallet="' + esc(u.wallet || '') + '"><strong>' + esc(u.username) + '</strong>' + (u.name ? ' <span style="color:#5a6573">— ' + esc(u.name) + '</span>' : '') + '<div class="ce-ta-meta">' + (u.email ? esc(u.email) + ' · ' : '') + 'TL' + (u.trust_level || 0) + ' · ' + fmtN(u.score || 0) + ' $RENO' + (u.wallet ? ' · 🔗 wallet linked' : '') + '</div></div>';
        }).join('');
        payTA.innerHTML = rows || '<div class="ce-ta-row" style="cursor:default;color:#8b95a3">No matches</div>';
        payTA.classList.add('is-open');
        $$('.ce-ta-row[data-uid]', payTA).forEach(function(r){
          r.addEventListener('click', function(){
            state.selectedUser = { id: r.getAttribute('data-uid'), username: r.getAttribute('data-uname'), wallet: r.getAttribute('data-wallet') };
            payQ.value = state.selectedUser.username;
            payTA.classList.remove('is-open');
            var sel = $('#ce-pay-selected'); sel.hidden = false; sel.innerHTML = '✓ Selected: <strong>@' + esc(state.selectedUser.username) + '</strong>' + (state.selectedUser.wallet ? ' (wallet: ' + esc(state.selectedUser.wallet.slice(0,6) + '...' + state.selectedUser.wallet.slice(-4)) + ')' : ' (no wallet linked)');
          });
        });
      });
    }, 220);
  });
  document.addEventListener('click', function(e){ if (!payQ.contains(e.target) && !payTA.contains(e.target)) payTA.classList.remove('is-open'); });

  $('#ce-pay-submit').addEventListener('click', function(){
    if (!state.selectedUser){ toast('Select a recipient first', 'err'); return; }
    var amt = parseInt($('#ce-pay-amt').value, 10) || 0;
    if (amt <= 0){ toast('Amount must be positive', 'err'); return; }
    var btn = $('#ce-pay-submit'); btn.disabled = true; btn.textContent = 'Sending...';
    post('/admin/coin-engine/payments.json', {
      user_id: state.selectedUser.id,
      amount: amt,
      reason: $('#ce-pay-reason').value,
      note: $('#ce-pay-note').value,
      wallet_address: $('#ce-pay-wallet').value.trim() || null,
    }).then(function(d){
      toast('Payment sent: +' + amt + ' $RENO to @' + state.selectedUser.username, 'win');
      $('#ce-pay-amt').value = ''; $('#ce-pay-note').value = ''; $('#ce-pay-wallet').value = '';
      $('#ce-pay-q').value = ''; $('#ce-pay-selected').hidden = true; state.selectedUser = null;
      state.recentLoaded = false; state.mintsLoaded = false;  // force-refresh
      loadStats();
    }).catch(function(err){
      toast((err && err.errors && err.errors[0]) || 'Payment failed', 'err');
    }).finally(function(){
      btn.disabled = false; btn.textContent = 'Send payment';
    });
  });

  // ---------- Recent tab ----------
  function loadRecent(){
    state.recentLoaded = true;
    var page = state.recentPage;
    get('/admin/coin-engine/payments.json?page=' + (page - 1) + '&limit=25').then(function(d){
      var rows = (d.payments || []);
      var body = $('#ce-recent-body');
      if (!rows.length){ body.innerHTML = '<tr><td colspan="6" class="ce-empty">No payments yet on this page.</td></tr>'; }
      else {
        body.innerHTML = rows.map(function(p){
          var status = p.tx_signature ? '<span class="ce-pill ce-pill-mint">Minted</span>' : '<span class="ce-pill ce-pill-sent">Sent</span>';
          var tx = p.tx_signature ? '<span class="ce-pill ce-pill-tx" title="' + esc(p.tx_signature) + '">' + esc(p.tx_signature.slice(0,8)) + '…' + esc(p.tx_signature.slice(-4)) + '</span>' : '<em style="color:#8b95a3">—</em>';
          return '<tr><td>' + fmtRel(p.sent_at || p.created_at) + '<div style="font-size:11px;color:#8b95a3">' + fmtFull(p.sent_at || p.created_at) + '</div></td>'
            + '<td><a href="/u/' + esc(p.username || '') + '" target="_blank">@' + esc(p.username || '?') + '</a></td>'
            + '<td class="ce-num"><strong>' + fmtN(p.amount) + '</strong></td>'
            + '<td>' + esc(p.reason || '—') + (p.note ? '<div style="font-size:11px;color:#8b95a3;margin-top:2px">' + esc(p.note) + '</div>' : '') + '</td>'
            + '<td>' + status + '</td>'
            + '<td>' + tx + '</td></tr>';
        }).join('');
      }
      $('#ce-recent-info').textContent = 'Page ' + page + (d.total ? ' · ' + d.total + ' total' : '');
      $('#ce-recent-prev').disabled = page <= 1;
      $('#ce-recent-next').disabled = rows.length < 25;
    }).catch(function(){
      $('#ce-recent-body').innerHTML = '<tr><td colspan="6" class="ce-empty">Failed to load. Retry.</td></tr>';
    });
  }
  $('#ce-recent-prev').addEventListener('click', function(){ if (state.recentPage > 1){ state.recentPage--; loadRecent(); }});
  $('#ce-recent-next').addEventListener('click', function(){ state.recentPage++; loadRecent(); });

  // ---------- Users tab ----------
  function loadUsers(){
    state.usersLoaded = true;
    var page = state.usersPage;
    var q = $('#ce-users-q').value.trim();
    var sort = $('#ce-users-sort').value;
    get('/admin/coin-engine/users.json?page=' + page + '&per_page=25&q=' + encodeURIComponent(q) + '&sort=' + encodeURIComponent(sort)).then(function(d){
      var rows = (d.users || []);
      var body = $('#ce-users-body');
      if (!rows.length){ body.innerHTML = '<tr><td colspan="6" class="ce-empty">No users match.</td></tr>'; }
      else {
        body.innerHTML = rows.map(function(u){
          var wallet = u.wallet ? '<span class="ce-pill ce-pill-tx" title="' + esc(u.wallet) + '">' + esc(u.wallet.slice(0,6) + '…' + u.wallet.slice(-4)) + '</span>' : '<em style="color:#8b95a3">none</em>';
          return '<tr><td><a href="/u/' + esc(u.username) + '" target="_blank">@' + esc(u.username) + '</a>' + (u.name ? '<div style="font-size:11px;color:#8b95a3">' + esc(u.name) + '</div>' : '') + '</td>'
            + '<td class="ce-num"><strong>' + fmtN(u.score) + '</strong></td>'
            + '<td class="ce-num">' + fmtN(u.lifetime_received) + '</td>'
            + '<td>' + (u.last_paid_at ? fmtRel(u.last_paid_at) : '<em style="color:#8b95a3">never</em>') + '</td>'
            + '<td>' + wallet + '</td>'
            + '<td><button class="ce-btn" data-payu="' + u.id + '" data-payname="' + esc(u.username) + '">Pay →</button></td></tr>';
        }).join('');
        $$('button[data-payu]', body).forEach(function(b){
          b.addEventListener('click', function(){
            state.selectedUser = { id: b.getAttribute('data-payu'), username: b.getAttribute('data-payname'), wallet: '' };
            $('#ce-pay-q').value = state.selectedUser.username;
            $('#ce-pay-selected').hidden = false; $('#ce-pay-selected').innerHTML = '✓ Selected: <strong>@' + esc(state.selectedUser.username) + '</strong>';
            $$('.ce-tab[data-tab="pay"]')[0].click();
            $('#ce-pay-amt').focus();
          });
        });
      }
      $('#ce-users-info').textContent = 'Page ' + page + (d.total ? ' · ' + d.total + ' users' : '');
      $('#ce-users-prev').disabled = page <= 1;
      $('#ce-users-next').disabled = rows.length < 25;
    }).catch(function(){
      $('#ce-users-body').innerHTML = '<tr><td colspan="6" class="ce-empty">Failed to load. Retry.</td></tr>';
    });
  }
  var usersTimer = null;
  $('#ce-users-q').addEventListener('input', function(){ clearTimeout(usersTimer); usersTimer = setTimeout(function(){ state.usersPage = 1; loadUsers(); }, 250); });
  $('#ce-users-sort').addEventListener('change', function(){ state.usersPage = 1; loadUsers(); });
  $('#ce-users-prev').addEventListener('click', function(){ if (state.usersPage > 1){ state.usersPage--; loadUsers(); }});
  $('#ce-users-next').addEventListener('click', function(){ state.usersPage++; loadUsers(); });

  // ---------- Mints tab ----------
  function loadMints(){
    state.mintsLoaded = true;
    get('/admin/coin-engine/payments.json?per_page=100&pending_mint=1').then(function(d){
      var rows = (d.payments || []).filter(function(p){ return !p.tx_signature; });
      var body = $('#ce-mints-body');
      if (!rows.length){ body.innerHTML = '<div class="ce-empty">All payments are minted. Nothing pending.</div>'; return; }
      body.innerHTML = rows.map(function(p){
        return '<div class="ce-mint-row" data-pid="' + p.id + '">'
          + '<div class="ce-mint-meta"><strong>+' + fmtN(p.amount) + ' $RENO</strong> to <a href="/u/' + esc(p.username || '') + '" target="_blank">@' + esc(p.username || '?') + '</a> · ' + fmtRel(p.sent_at || p.created_at) + ' · reason: ' + esc(p.reason || '—') + '</div>'
          + '<div class="ce-mint-input"><input type="text" class="ce-input" placeholder="Paste Solana transaction signature (base58)" data-pid="' + p.id + '"><button class="ce-btn ce-btn-primary" data-mintp="' + p.id + '">Mark minted</button></div>'
          + '</div>';
      }).join('');
      $$('button[data-mintp]', body).forEach(function(btn){
        btn.addEventListener('click', function(){
          var pid = btn.getAttribute('data-mintp');
          var input = body.querySelector('input[data-pid="' + pid + '"]');
          var sig = (input && input.value || '').trim();
          if (!sig){ toast('Paste the Solana tx signature first', 'err'); return; }
          btn.disabled = true; btn.textContent = 'Saving...';
          put('/admin/coin-engine/payments/' + pid + '/tx.json', { tx_signature: sig }).then(function(){
            toast('Marked as minted', 'win');
            var row = body.querySelector('.ce-mint-row[data-pid="' + pid + '"]');
            if (row){ row.classList.add('ce-mint-done'); btn.textContent = '✓ Done'; input.disabled = true; }
            loadStats();
            state.recentLoaded = false;
          }).catch(function(err){
            toast((err && err.errors && err.errors[0]) || 'Failed to save tx', 'err');
            btn.disabled = false; btn.textContent = 'Mark minted';
          });
        });
      });
    }).catch(function(){
      $('#ce-mints-body').innerHTML = '<div class="ce-empty">Failed to load pending mints.</div>';
    });
  }

  // Boot
  loadStats();
  setInterval(loadStats, 60000); // refresh stats every minute
})();
</script>

<%# v0.8.0 — Solana on-chain payment integration. Browser-side only:
    admin connects Phantom wallet, signs each transfer manually. We never
    store private keys. SPL token transfer = create-ATA-if-missing + transfer.
%>
<script nonce="<%= csp_nonce_placeholder %>" src="https://unpkg.com/@solana/web3.js@1.95.5/lib/index.iife.min.js"></script>
<script nonce="<%= csp_nonce_placeholder %>" src="https://unpkg.com/@solana/spl-token@0.4.8/lib/index.iife.min.js"></script>
<script nonce="<%= csp_nonce_placeholder %>">
(function(){
  if (window.__lfCESolanaLoaded) return; window.__lfCESolanaLoaded = true;

  // ---------- Config from server ----------
  var SOL_MINT     = "<%= j SiteSetting.coin_engine_solana_mint_address.to_s %>";
  var SOL_RPC      = "<%= j SiteSetting.coin_engine_solana_rpc_url.to_s %>";
  var SOL_DECIMALS = parseInt("<%= SiteSetting.coin_engine_solana_decimals.to_i %>", 10) || 9;
  var SOL_MIN      = parseInt("<%= SiteSetting.coin_engine_solana_min_send_threshold.to_i %>", 10) || 20000;
  var COIN_NAME    = "<%= j SiteSetting.coin_engine_coin_name.to_s %>";

  function $(s, r){ return (r||document).querySelector(s); }
  function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, function(c){ return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]; }); }
  function toast(m, k){ var t=document.createElement('div'); t.className='ce-toast'+(k?' ce-toast-'+k:''); t.textContent=m; document.body.appendChild(t); setTimeout(function(){t.classList.add('ce-toast-out');},2400); setTimeout(function(){if(t.parentNode)t.parentNode.removeChild(t);},3000); }

  // ---------- Wallet state ----------
  var wallet = { connected: false, pubkey: null };
  function loadStoredConnection(){
    try {
      var saved = localStorage.getItem('lf_ce_admin_wallet');
      if (saved){ wallet.pubkey = saved; wallet.connected = true; }
    } catch(_){}
  }
  function saveConnection(pk){
    try { localStorage.setItem('lf_ce_admin_wallet', pk); } catch(_){}
  }
  function clearConnection(){
    try { localStorage.removeItem('lf_ce_admin_wallet'); } catch(_){}
    wallet.connected = false; wallet.pubkey = null;
  }

  // ---------- Inject UI ----------
  function injectChainPanel(){
    if (document.getElementById('ce-chain-panel')) return;
    var payPanel = document.getElementById('ce-pane-pay');
    if (!payPanel) return;
    var configured = !!SOL_MINT;
    var html =
      '<div id="ce-chain-panel" style="margin-bottom:18px;padding:14px;border-radius:12px;background:linear-gradient(135deg,#0f1624,#1d2a44);color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">'+
        '<div style="flex:1;min-width:240px">'+
          '<div style="font-size:11.5px;text-transform:uppercase;letter-spacing:.6px;opacity:.65;font-weight:700">⛓️ On-chain payments</div>'+
          '<div id="ce-chain-status" style="font-size:14px;font-weight:700;margin-top:4px"></div>'+
          '<div id="ce-chain-detail" style="font-size:11.5px;opacity:.7;margin-top:3px"></div>'+
        '</div>'+
        '<div id="ce-chain-actions" style="display:flex;gap:8px;flex-wrap:wrap"></div>'+
      '</div>';
    payPanel.insertAdjacentHTML('afterbegin', html);
    renderChainStatus();
  }
  function renderChainStatus(){
    var statusEl = $('#ce-chain-status'); var detailEl = $('#ce-chain-detail'); var actionsEl = $('#ce-chain-actions');
    if (!statusEl) return;
    if (!SOL_MINT){
      statusEl.innerHTML = '⚠️ Mint address not configured';
      detailEl.textContent = 'Set coin_engine_solana_mint_address in Site Settings to enable on-chain transfers.';
      actionsEl.innerHTML = '<a href="/admin/site_settings/category/plugins?filter=coin_engine_solana" target="_blank" style="color:#fff;text-decoration:underline;font-size:12.5px">Configure →</a>';
      return;
    }
    if (!window.solana){
      statusEl.innerHTML = '🦊 Phantom wallet not detected';
      detailEl.textContent = 'Install Phantom (phantom.app) to enable on-chain payments. Manual recording still works without it.';
      actionsEl.innerHTML = '<a href="https://phantom.app" target="_blank" style="color:#fff;text-decoration:underline;font-size:12.5px">Install Phantom →</a>';
      return;
    }
    if (wallet.connected && wallet.pubkey){
      var short = wallet.pubkey.slice(0,6)+'…'+wallet.pubkey.slice(-4);
      statusEl.innerHTML = '✅ Connected · <code style="background:rgba(255,255,255,.12);padding:1px 6px;border-radius:4px;font-size:12px;font-family:ui-monospace,Menlo,monospace">'+esc(short)+'</code>';
      detailEl.textContent = 'Mint: '+SOL_MINT.slice(0,6)+'…'+SOL_MINT.slice(-4)+' · Min on-chain send: '+SOL_MIN.toLocaleString()+' '+esc(COIN_NAME)+' · RPC: '+(SOL_RPC.replace(/^https?:\/\//,'').split('/')[0]);
      actionsEl.innerHTML = '<button class="ce-btn" id="ce-chain-disconnect" style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2)">Disconnect</button>';
      $('#ce-chain-disconnect').addEventListener('click', function(){ clearConnection(); renderChainStatus(); injectOnChainToggle(); });
    } else {
      statusEl.textContent = 'Wallet not connected';
      detailEl.textContent = 'Connect to enable on-chain auto-mint when issuing payments. Without connection, payments still record (admins can mint manually later).';
      actionsEl.innerHTML = '<button class="ce-btn ce-btn-primary" id="ce-chain-connect">Connect Phantom Wallet</button>';
      $('#ce-chain-connect').addEventListener('click', connectWallet);
    }
    injectOnChainToggle();
  }

  async function connectWallet(){
    if (!window.solana){ toast('Phantom not detected', 'err'); return; }
    try {
      var resp = await window.solana.connect();
      var pk = resp.publicKey ? resp.publicKey.toString() : (window.solana.publicKey && window.solana.publicKey.toString());
      if (!pk) throw new Error('No public key returned');
      wallet.connected = true; wallet.pubkey = pk; saveConnection(pk);
      toast('Wallet connected: '+pk.slice(0,6)+'…'+pk.slice(-4), 'win');
      renderChainStatus();
    } catch(e){ toast('Wallet connection rejected', 'err'); }
  }

  // ---------- "Send on-chain" toggle in Pay form ----------
  function injectOnChainToggle(){
    var actionsRow = document.querySelector('#ce-pane-pay .ce-toolbar:last-of-type');
    if (!actionsRow) return;
    var existing = document.getElementById('ce-pay-onchain-wrap');
    if (existing) existing.remove();
    var wrap = document.createElement('div');
    wrap.id = 'ce-pay-onchain-wrap';
    wrap.style.cssText = 'flex:1;display:flex;align-items:center;gap:8px;font-size:13px;color:#5a6573';
    var disabled = !(SOL_MINT && wallet.connected && window.solana);
    wrap.innerHTML =
      '<label style="display:inline-flex;align-items:center;gap:8px;cursor:'+(disabled?'not-allowed':'pointer')+';opacity:'+(disabled?'.5':'1')+'">'+
        '<input type="checkbox" id="ce-pay-onchain" '+(disabled?'disabled':'')+' style="width:16px;height:16px;cursor:'+(disabled?'not-allowed':'pointer')+'">'+
        '<span><strong>Auto-mint on Solana</strong>'+(disabled? ' (connect wallet first)' : ' (admin signs in Phantom)')+'</span>'+
      '</label>';
    actionsRow.insertBefore(wrap, actionsRow.firstChild);
  }

  // ---------- SPL token transfer ----------
  async function getRecipientWallet(username){
    // Backend already returns wallet on the user search response. Re-fetch to be safe.
    var r = await fetch('/admin/coin-engine/users.json?per_page=1&q='+encodeURIComponent(username), { credentials:'same-origin', headers: { 'Accept':'application/json' } });
    var d = await r.json();
    var u = (d.users || []).find(function(x){ return (x.username||'').toLowerCase() === username.toLowerCase(); });
    return u && u.wallet;
  }

  async function sendSplTransfer(recipientPubkeyStr, amount){
    var web3 = window.solanaWeb3;
    var spl  = window.splToken;
    if (!web3 || !spl) throw new Error('Solana libraries not loaded');

    var conn = new web3.Connection(SOL_RPC, 'confirmed');
    var sender = window.solana.publicKey;
    var recipient = new web3.PublicKey(recipientPubkeyStr);
    var mint = new web3.PublicKey(SOL_MINT);

    var senderAta    = await spl.getAssociatedTokenAddress(mint, sender);
    var recipientAta = await spl.getAssociatedTokenAddress(mint, recipient);

    var instructions = [];
    var rcptInfo = await conn.getAccountInfo(recipientAta);
    if (!rcptInfo){
      instructions.push(spl.createAssociatedTokenAccountInstruction(sender, recipientAta, recipient, mint));
    }
    var rawAmount = BigInt(amount) * BigInt(Math.pow(10, SOL_DECIMALS));
    instructions.push(spl.createTransferInstruction(senderAta, recipientAta, sender, rawAmount));

    var blockhash = await conn.getLatestBlockhash('confirmed');
    var tx = new web3.Transaction({ recentBlockhash: blockhash.blockhash, feePayer: sender });
    instructions.forEach(function(ix){ tx.add(ix); });

    var signed = await window.solana.signAndSendTransaction(tx);
    var sig = signed.signature || signed; // Phantom returns {signature}
    await conn.confirmTransaction({ signature: sig, ...blockhash }, 'confirmed');
    return sig;
  }

  // ---------- Hook the existing payment submit ----------
  function hookPaymentSubmit(){
    var btn = document.getElementById('ce-pay-submit');
    if (!btn || btn.__lfWeb3Wrapped) return;
    btn.__lfWeb3Wrapped = true;

    btn.addEventListener('click', async function(e){
      var checkbox = document.getElementById('ce-pay-onchain');
      if (!checkbox || !checkbox.checked) return; // backend records, no on-chain step
      // We need to wait for the backend POST to land first, capture the payment_id, then sign.
      // The existing handler already POSTs and handles success. We patch by intercepting fetch.
    }, true);

    // Intercept window.fetch ONLY for our specific POST so we can chain after success
    var origFetch = window.fetch;
    window.fetch = function(url, opts){
      var p = origFetch.apply(this, arguments);
      if (url === '/admin/coin-engine/payments.json' && opts && opts.method === 'POST'){
        var checkbox = document.getElementById('ce-pay-onchain');
        if (checkbox && checkbox.checked && wallet.connected){
          p = p.then(async function(resp){
            try {
              var clone = resp.clone();
              var d = await clone.json();
              if (d && d.ok && d.payment){
                var amt = d.payment.amount;
                if (amt < SOL_MIN){
                  toast('Amount below min on-chain threshold ('+SOL_MIN.toLocaleString()+'). Recorded only.', 'info');
                  return resp;
                }
                var username = d.payment.username || (d.payment.user && d.payment.user.username);
                var recipientWallet = d.payment.wallet || (username ? await getRecipientWallet(username) : null);
                if (!recipientWallet){
                  toast('Recipient has no wallet linked. Recorded only — they can claim later.', 'info');
                  return resp;
                }
                toast('Signing transaction in Phantom...', 'info');
                var sig = await sendSplTransfer(recipientWallet, amt);
                // Save the tx signature against the payment
                await origFetch('/admin/coin-engine/payments/'+d.payment.id+'/tx.json', {
                  method: 'PUT', credentials: 'same-origin',
                  headers: { 'Content-Type':'application/json', 'X-CSRF-Token': (document.querySelector('meta[name=csrf-token]')||{}).getAttribute && document.querySelector('meta[name=csrf-token]').getAttribute('content') },
                  body: JSON.stringify({ tx_signature: sig })
                });
                toast('✅ Minted on-chain · '+sig.slice(0,8)+'…', 'win');
              }
            } catch(err){
              toast('On-chain mint failed: '+(err.message||err), 'err');
              console.error('[ce-solana]', err);
            }
            return resp;
          });
        }
      }
      return p;
    };
  }

  // ---------- Boot ----------
  function boot(){
    loadStoredConnection();
    injectChainPanel();
    hookPaymentSubmit();
    // Try to reconnect silently if Phantom was previously approved
    if (window.solana && window.solana.connect){
      window.solana.connect({ onlyIfTrusted: true }).then(function(r){
        if (r && r.publicKey){ wallet.pubkey = r.publicKey.toString(); wallet.connected = true; saveConnection(wallet.pubkey); renderChainStatus(); }
      }).catch(function(){});
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else setTimeout(boot, 50);
})();
</script>

</body>
</html>
