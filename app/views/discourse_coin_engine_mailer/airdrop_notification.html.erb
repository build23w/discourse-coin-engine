<table style="max-width:520px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;color:#1a2332;">
  <tr>
    <td style="padding:24px 0;text-align:center;">
      <div style="font-size:48px;line-height:1;">&#127873;</div>
      <h1 style="margin:14px 0 6px;font-size:24px;font-weight:800;">+<%= number_with_delimiter(@amount) %> <%= @coin_name %></h1>
      <p style="margin:0;color:#5a6573;font-size:14px;line-height:1.5;">
        <%= t('discourse_coin_engine.airdrop.body', amount: @amount, coin: @coin_name, site_name: @site_name, reason: @reason) %>
      </p>
    </td>
  </tr>
  <tr>
    <td style="padding:18px 0;text-align:center;">
      <a href="<%= @site_url %>/leaderboard/1" style="display:inline-block;background:<%= @brand_color %>;color:#fff;text-decoration:none;font-weight:700;padding:12px 24px;border-radius:8px;font-size:14px;">See your balance &rarr;</a>
    </td>
  </tr>
  <tr>
    <td style="padding:18px 0 8px;text-align:center;font-size:12px;color:#8b95a3;">
      Audit your credit on the <a href="<%= @ledger_url %>" style="color:#8b95a3;">public payment ledger</a>.
    </td>
  </tr>
</table>
