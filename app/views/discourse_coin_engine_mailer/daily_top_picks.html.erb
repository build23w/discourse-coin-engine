<style type="text/css">
  /* v0.19.3 — Mobile responsive layer for coin-engine emails.
     iOS Mail / Apple Mail / native Android Gmail honour these.
     Gmail web / Outlook desktop strip <style> blocks so they fall back
     to the desktop inline styles, which is fine for wide viewports. */
  @media only screen and (max-width: 480px) {
    /* Outer table: cap width but allow shrink, add side gutters */
    table[role="presentation"][style*="max-width:560px"],
    table[role="presentation"][style*="max-width:520px"],
    table[style*="max-width:560px"],
    table[style*="max-width:520px"] {
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 12px !important;
      box-sizing: border-box !important;
    }
    /* Hero numbers (the +earned, #rank, +amount big digits) */
    div[style*="font-size:46px"] { font-size: 32px !important; letter-spacing: -1px !important; }
    div[style*="font-size:36px"] { font-size: 26px !important; letter-spacing: -.5px !important; }
    /* Hero emoji rows */
    div[style*="font-size:54px"] { font-size: 40px !important; }
    div[style*="font-size:48px"] { font-size: 36px !important; }
    /* H1 headings */
    h1[style*="font-size:26px"] { font-size: 20px !important; line-height: 1.25 !important; }
    h1[style*="font-size:24px"] { font-size: 19px !important; line-height: 1.25 !important; }
    /* Generous outer-cell padding */
    td[style*="padding:24px 0 14px"] { padding: 18px 0 10px !important; }
    td[style*="padding:24px 0 8px"]  { padding: 18px 0 6px !important; }
    td[style*="padding:24px 0"]      { padding: 18px 0 !important; }
    td[style*="padding:28px 0 22px"] { padding: 20px 0 16px !important; }
    td[style*="padding:26px 22px"]   { padding: 20px 16px !important; }
    td[style*="padding:18px 22px"]   { padding: 14px 16px !important; }
    td[style*="padding:14px 18px"]   { padding: 12px 14px !important; }
    /* CTA buttons */
    a[style*="padding:13px 28px"] { padding: 12px 22px !important; font-size: 13.5px !important; }
    a[style*="padding:12px 24px"] { padding: 11px 20px !important; font-size: 13px !important; }
    /* Body copy */
    p[style*="font-size:14px"]   { font-size: 13px !important; }
    p[style*="font-size:13.5px"] { font-size: 12.5px !important; }
    /* Topic/leaderboard rows: tighter padding so multi-column tables fit */
    td[style*="padding:10px 6px"] { padding: 8px 4px !important; font-size: 13px !important; }
    /* Receipt key/value table on phones — give value column more room */
    td[style*="width:35%"] { width: 38% !important; padding-left: 12px !important; padding-right: 8px !important; }
  }
</style>
<table role="presentation" style="max-width:560px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;color:#1a2332;width:100%;">
  <tr>
    <td style="padding:24px 0 14px;">
      <div style="display:inline-block;padding:4px 12px;background:<%= @brand_color %>;color:#fff;font-size:10.5px;font-weight:800;letter-spacing:1.4px;border-radius:999px;">TODAY</div>
      <h1 style="margin:14px 0 6px;font-size:24px;font-weight:900;letter-spacing:-.3px;line-height:1.2;">Hottest threads on <%= @site_name %></h1>
      <p style="margin:0;color:#5a6573;font-size:13.5px;line-height:1.5;">Five conversations gaining real heat right now &mdash; jump in early and the <%= @coin_name %> per reply scales with engagement.</p>
    </td>
  </tr>

  <tr>
    <td style="padding:8px 0 8px;">
      <% @top_topics.first(5).each_with_index do |row, i| %>
        <% id, title, slug, views, posts_count, like_count = row %>
        <% est = (views.to_i + 5*like_count.to_i + 10*posts_count.to_i) %>
        <% tier = est >= 2000 ? '&#128293;' : (est >= 500 ? '&#11088;' : '&#9999;') %>
        <a href="<%= @site_url %>/t/<%= slug %>/<%= id %>" style="display:block;padding:14px 16px;border:1px solid #eef1f6;border-left:3px solid <%= @brand_color %>;border-radius:10px;margin-bottom:8px;text-decoration:none;color:#1a2332;">
          <div style="font-size:14.5px;font-weight:700;line-height:1.35;margin-bottom:4px;"><%= raw tier %> <%= title %></div>
          <div style="font-size:11.5px;color:#8b95a3;letter-spacing:.2px;">
            <%= number_with_delimiter(views.to_i) %> views &middot;
            <%= posts_count.to_i %> reply<%= posts_count.to_i == 1 ? '' : 'ies' %> &middot;
            <%= like_count.to_i %> like<%= like_count.to_i == 1 ? '' : 's' %>
          </div>
        </a>
      <% end %>
    </td>
  </tr>

  <tr>
    <td style="padding:18px 0 0;text-align:center;">
      <a href="<%= @site_url %>/" style="display:inline-block;background:<%= @brand_color %>;color:#fff;text-decoration:none;font-weight:700;padding:13px 28px;border-radius:8px;font-size:14.5px;">Open the feed &rarr;</a>
    </td>
  </tr>

  <tr>
    <td style="padding:24px 0 8px;font-size:12px;color:#8b95a3;text-align:center;line-height:1.7;">
      You're getting this because email digests are on. <a href="<%= @site_url %>/my/preferences/emails" style="color:#8b95a3;text-decoration:underline;">Quiet these</a>.
    </td>
  </tr>
</table>
