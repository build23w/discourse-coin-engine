<table style="max-width:560px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;color:#1a2332;">
  <tr>
    <td style="padding:24px 0;border-bottom:3px solid <%= @brand_color %>;">
      <h1 style="margin:0;font-size:22px;font-weight:800;">Your week on <%= @site_name %></h1>
      <p style="margin:6px 0 0;color:#5a6573;font-size:13px;">Here's how you did, <strong><%= @user.username %></strong>.</p>
    </td>
  </tr>
  <tr>
    <td style="padding:24px 0;text-align:center;background:#fff3eb;border-radius:12px;margin-top:16px;">
      <div style="font-size:11px;font-weight:800;color:<%= @brand_color %>;letter-spacing:1.4px;text-transform:uppercase;">Earned this week</div>
      <div style="font-size:38px;font-weight:900;color:#1a2332;line-height:1.1;margin:6px 0 2px;"><%= number_with_delimiter(@week_earned) %></div>
      <div style="font-size:13px;font-weight:700;color:<%= @brand_color %>;letter-spacing:.5px;"><%= @coin_name %></div>
    </td>
  </tr>
  <% if @streak_days && @streak_days > 0 %>
    <tr>
      <td style="padding:18px 0;font-size:14px;">
        <span style="display:inline-block;padding:5px 12px;background:#1a2332;color:#fff;border-radius:999px;font-weight:700;font-size:12px;">&#128293; <%= @streak_days %>-day streak</span>
      </td>
    </tr>
  <% end %>
  <% if @recent_badges && @recent_badges.any? %>
    <tr>
      <td style="padding:18px 0;">
        <h2 style="margin:0 0 12px;font-size:15px;font-weight:700;color:<%= @brand_color %>;letter-spacing:.4px;text-transform:uppercase;">New badges this week</h2>
        <% @recent_badges.each do |b| %>
          <div style="padding:10px 14px;border:1px solid #eef1f6;border-radius:8px;margin-bottom:6px;font-size:14px;font-weight:600;">
            <%= b[:name] %><% if b[:allow_title] %> <span style="color:#5a6573;font-size:12px;font-weight:500;">&middot; title unlocked</span><% end %>
          </div>
        <% end %>
      </td>
    </tr>
  <% end %>
  <tr>
    <td style="padding:24px 0 0;text-align:center;">
      <a href="<%= @site_url %>/" style="display:inline-block;background:<%= @brand_color %>;color:#fff;text-decoration:none;font-weight:700;padding:12px 24px;border-radius:8px;font-size:14px;">Back to <%= @site_name %> &rarr;</a>
    </td>
  </tr>
  <tr>
    <td style="padding:24px 0 8px;font-size:12px;color:#8b95a3;text-align:center;">
      <a href="<%= @site_url %>/my/preferences/emails" style="color:#8b95a3;">Email settings</a>
    </td>
  </tr>
</table>
