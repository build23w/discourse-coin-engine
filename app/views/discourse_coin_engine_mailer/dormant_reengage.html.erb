<table style="max-width:560px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;color:#1a2332;">
  <tr>
    <td style="padding:24px 0;border-bottom:3px solid <%= @brand_color %>;">
      <h1 style="margin:0;font-size:22px;font-weight:800;"><%= t('discourse_coin_engine.dormant_reengage.subject', site_name: @site_name) %></h1>
      <p style="margin:6px 0 0;color:#5a6573;font-size:13px;"><%= t('discourse_coin_engine.dormant_reengage.intro') %></p>
    </td>
  </tr>
  <% if @top_topics && @top_topics.any? %>
    <tr>
      <td style="padding:18px 0;">
        <h2 style="margin:0 0 12px;font-size:15px;font-weight:700;color:<%= @brand_color %>;letter-spacing:.4px;text-transform:uppercase;">Trending topics</h2>
        <% @top_topics.each do |id, title, slug, views| %>
          <div style="padding:10px 14px;border:1px solid #eef1f6;border-radius:8px;margin-bottom:6px;">
            <a href="<%= @site_url %>/t/<%= slug %>/<%= id %>" style="color:#1a2332;font-size:14px;font-weight:600;text-decoration:none;display:block;">
              <%= title %>
            </a>
            <span style="color:#8b95a3;font-size:11.5px;"><%= number_with_delimiter(views) %> views</span>
          </div>
        <% end %>
      </td>
    </tr>
  <% end %>
  <tr>
    <td style="padding:18px 0 0;text-align:center;">
      <a href="<%= @site_url %>/" style="display:inline-block;background:<%= @brand_color %>;color:#fff;text-decoration:none;font-weight:700;padding:12px 24px;border-radius:8px;font-size:14px;">Catch up &rarr;</a>
    </td>
  </tr>
  <tr>
    <td style="padding:24px 0 8px;font-size:12px;color:#8b95a3;text-align:center;">
      <a href="<%= @site_url %>/my/preferences/emails" style="color:#8b95a3;">Unsubscribe from these</a>
    </td>
  </tr>
</table>
