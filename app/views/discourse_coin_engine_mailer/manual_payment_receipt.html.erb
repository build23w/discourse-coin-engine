<table role="presentation" style="max-width:560px;margin:0 auto;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;color:#1a2332;width:100%;">
  <tr>
    <td style="padding:28px 0 22px;text-align:center;">
      <div style="font-size:54px;line-height:1;">&#127873;</div>
      <h1 style="margin:14px 0 6px;font-size:26px;font-weight:900;letter-spacing:-.3px;">+<%= number_with_delimiter(@amount) %> <%= @coin_name %></h1>
      <p style="margin:0;color:#5a6573;font-size:14px;line-height:1.5;">credited to <strong>@<%= @user.username %></strong>'s account</p>
    </td>
  </tr>
  <tr>
    <td style="padding:6px 0 18px;">
      <table role="presentation" style="width:100%;border-collapse:collapse;background:#f7f9fc;border:1px solid rgba(15,22,36,.08);border-radius:12px;">
        <tr>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:13px;color:#5a6573;width:35%;">Receipt</td>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:13.5px;font-weight:700;">#<%= @payment_id %></td>
        </tr>
        <tr>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:13px;color:#5a6573;">Amount</td>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:14px;font-weight:800;color:<%= @brand_color %>;">+<%= number_with_delimiter(@amount) %> <%= @coin_name %></td>
        </tr>
        <tr>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:13px;color:#5a6573;">Reason</td>
          <td style="padding:14px 18px;border-bottom:1px solid #eef1f6;font-size:13.5px;"><%= @reason %></td>
        </tr>
        <tr>
          <td style="padding:14px 18px;font-size:13px;color:#5a6573;">Issued by</td>
          <td style="padding:14px 18px;font-size:13.5px;">@<%= @issued_by %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:14px 0 0;text-align:center;">
      <a href="<%= @site_url %>/leaderboard/1" style="display:inline-block;background:<%= @brand_color %>;color:#fff;text-decoration:none;font-weight:700;padding:12px 24px;border-radius:8px;font-size:14px;">View your balance &rarr;</a>
    </td>
  </tr>
  <tr>
    <td style="padding:18px 0 6px;text-align:center;font-size:12px;color:#8b95a3;line-height:1.6;">
      This credit is logged on the <a href="<%= @ledger_url %>" style="color:#8b95a3;text-decoration:underline;">public payment ledger</a> for full transparency.<br>
      A receipt is also waiting for you in your <a href="<%= @site_url %>/my/messages" style="color:#8b95a3;text-decoration:underline;">forum messages</a>.
    </td>
  </tr>
  <tr>
    <td style="padding:18px 0 8px;text-align:center;font-size:11.5px;color:#aab1bc;">
      <a href="<%= @site_url %>/my/preferences/emails" style="color:#aab1bc;">Email preferences</a>
    </td>
  </tr>
</table>
